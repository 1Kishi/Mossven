---
// Sdílený layout pro ukázkový (demo) vícestránkový web fiktivního
// kadeřnictví „Studio Luma". Samostatná identita — nepoužívá Mossven Layout.
// Všechny třídy mají prefix `luma-`, aby nedošlo ke konfliktu s globálními
// styly Mossven webu (.section, .cta, .button apod.).
// Soubor je ve složce s podtržítkem (_layout), takže ho Astro nebere jako routu.

interface Props {
  title: string;
  description: string;
  active: "uvod" | "sluzby" | "cenik" | "galerie" | "tym" | "blog" | "kontakt";
  /** Akcentní barva headeru stránky — drží sérii vizuálně konzistentní, ale ne identickou. */
  accent?: "coral" | "copper" | "magenta" | "jade";
}

const { title, description, active, accent = "coral" } = Astro.props;

const base = "/ukazky/kadernictvi";
const nav = [
  { key: "uvod", label: "Úvod", href: `${base}` },
  { key: "sluzby", label: "Služby", href: `${base}/sluzby` },
  { key: "cenik", label: "Ceník", href: `${base}/cenik` },
  { key: "galerie", label: "Galerie", href: `${base}/galerie` },
  { key: "tym", label: "Tým", href: `${base}/tym` },
  { key: "blog", label: "Blog", href: `${base}/blog` },
  { key: "kontakt", label: "Kontakt", href: `${base}/kontakt` },
];
---

<!doctype html>
<html lang="cs" data-accent={accent}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Instrument+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="luma-body">
    <a class="luma-skip" href="#luma-main">Přeskočit na obsah</a>

    <header class="luma-nav" id="luma-top">
      <div class="luma-wrap luma-nav__inner">
        <a class="luma-brand" href={base} aria-label="Studio Luma — úvod">
          <span class="luma-brand__mark" aria-hidden="true">
            <svg viewBox="0 0 40 40" width="34" height="34">
              <path d="M8 30 C 14 12, 26 12, 32 30" fill="none" stroke="var(--luma-coral)" stroke-width="3" stroke-linecap="round" />
              <path d="M12 31 C 17 18, 23 18, 28 31" fill="none" stroke="var(--luma-copper)" stroke-width="3" stroke-linecap="round" />
              <path d="M16 32 C 19 24, 21 24, 24 32" fill="none" stroke="var(--luma-magenta)" stroke-width="3" stroke-linecap="round" />
            </svg>
          </span>
          <span class="luma-brand__name">Studio&nbsp;Luma</span>
        </a>

        <nav class="luma-nav__links" aria-label="Hlavní navigace">
          {nav.map((n) => (
            <a
              href={n.href}
              class:list={["luma-nav__link", { "is-active": active === n.key }]}
              aria-current={active === n.key ? "page" : undefined}
            >
              {n.label}
            </a>
          ))}
        </nav>

        <a class="luma-btn luma-btn--solid luma-nav__cta" href={`${base}/kontakt`}>Objednat termín</a>

        <button class="luma-burger" type="button" aria-expanded="false" aria-controls="luma-mobile" aria-label="Otevřít menu">
          <span></span><span></span><span></span>
        </button>
      </div>

      <div class="luma-mobile" id="luma-mobile" hidden>
        <nav class="luma-mobile__nav" aria-label="Mobilní navigace">
          {nav.map((n) => (
            <a
              href={n.href}
              class:list={["luma-mobile__link", { "is-active": active === n.key }]}
              aria-current={active === n.key ? "page" : undefined}
            >
              {n.label}
            </a>
          ))}
          <a class="luma-btn luma-btn--solid luma-mobile__cta" href={`${base}/kontakt`}>Objednat termín</a>
        </nav>
      </div>
    </header>

    <main id="luma-main">
      <slot />
    </main>

    <footer class="luma-foot">
      <div class="luma-wrap luma-foot__inner">
        <div class="luma-foot__brand">
          <span class="luma-brand__name luma-foot__name">Studio&nbsp;Luma</span>
          <p class="luma-foot__tag">Barva, střih a péče s rukopisem. Kadeřnický ateliér v Českých Budějovicích.</p>
        </div>
        <nav class="luma-foot__links" aria-label="Navigace v patičce">
          {nav.map((n) => (
            <a href={n.href} class="luma-foot__link">{n.label}</a>
          ))}
        </nav>
        <div class="luma-foot__meta">
          <p>Náměstí 12, České Budějovice</p>
          <p>+420 777 234 567</p>
          <p>studio.luma@example.cz</p>
        </div>
      </div>
      <div class="luma-wrap luma-foot__bottom">
        <p class="luma-foot__demo">
          Demo web vytvořený jako ukázka řešení od <a href="/" class="luma-foot__mossven">Mossven</a>.
        </p>
        <p class="luma-foot__year">© <span id="luma-yr"></span> Studio Luma — ukázka</p>
      </div>
    </footer>

    <script>
      // Rok do patičky
      const yr = document.getElementById("luma-yr");
      if (yr) yr.textContent = String(new Date().getFullYear());

      // Mobilní menu
      const burger = document.querySelector(".luma-burger");
      const mobile = document.getElementById("luma-mobile");
      if (burger && mobile) {
        burger.addEventListener("click", () => {
          const open = burger.getAttribute("aria-expanded") === "true";
          burger.setAttribute("aria-expanded", String(!open));
          burger.classList.toggle("is-open", !open);
          if (open) {
            mobile.hidden = true;
          } else {
            mobile.hidden = false;
          }
        });
      }

      // Jemné odhalení obsahu při načtení (respektuje prefers-reduced-motion přes CSS)
      requestAnimationFrame(() => document.body.classList.add("luma-ready"));
    </script>

    <style is:global>
      /* ============ RESET ============ */
      .luma-body *, .luma-body *::before, .luma-body *::after { box-sizing: border-box; }
      .luma-body { margin: 0; }

      /* ============ TOKENY ============ */
      :root {
        --luma-ink: #2A1622;
        --luma-ink-soft: #6A5560;
        --luma-paper: #FBF3EA;
        --luma-paper-2: #F4E7DA;
        --luma-card: #FFFFFF;
        --luma-coral: #FF5A3C;
        --luma-copper: #E2922F;
        --luma-magenta: #D43B72;
        --luma-jade: #168B6F;
        --luma-line: rgba(42, 22, 34, 0.12);
        --luma-line-soft: rgba(42, 22, 34, 0.07);
        --luma-shadow: 0 26px 60px -34px rgba(42, 22, 34, 0.45);
        --luma-shadow-sm: 0 10px 30px -18px rgba(42, 22, 34, 0.4);
        --luma-ff-display: "Fraunces", Georgia, "Times New Roman", serif;
        --luma-ff-body: "Instrument Sans", system-ui, -apple-system, sans-serif;
        --luma-maxw: 1180px;
        --luma-r: 22px;
        --luma-r-sm: 14px;
        --luma-ease: cubic-bezier(0.22, 0.61, 0.36, 1);
      }

      /* Akcent stránky */
      [data-accent="coral"] { --luma-accent: var(--luma-coral); }
      [data-accent="copper"] { --luma-accent: var(--luma-copper); }
      [data-accent="magenta"] { --luma-accent: var(--luma-magenta); }
      [data-accent="jade"] { --luma-accent: var(--luma-jade); }

      .luma-body {
        font-family: var(--luma-ff-body);
        color: var(--luma-ink);
        background: var(--luma-paper);
        background-image:
          radial-gradient(120% 80% at 88% -10%, color-mix(in srgb, var(--luma-copper) 14%, transparent), transparent 60%),
          radial-gradient(90% 70% at -8% 8%, color-mix(in srgb, var(--luma-magenta) 9%, transparent), transparent 55%);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      .luma-wrap { width: min(var(--luma-maxw), 92vw); margin-inline: auto; }

      /* ============ TYPOGRAFIE ============ */
      .luma-body h1, .luma-body h2, .luma-body h3, .luma-body h4 {
        font-family: var(--luma-ff-display);
        font-weight: 600;
        line-height: 1.05;
        margin: 0;
        letter-spacing: -0.01em;
      }
      .luma-eyebrow {
        font-size: 0.74rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--luma-accent, var(--luma-coral));
        margin: 0 0 0.9rem;
      }
      .luma-lede { font-size: 1.18rem; color: var(--luma-ink-soft); max-width: 56ch; }

      a { color: inherit; }

      /* ============ TLAČÍTKA ============ */
      .luma-btn {
        display: inline-flex; align-items: center; gap: 0.5em;
        font-family: var(--luma-ff-body); font-weight: 600; font-size: 0.98rem;
        padding: 0.78em 1.4em; border-radius: 999px; border: 2px solid transparent;
        text-decoration: none; cursor: pointer; line-height: 1;
        transition: transform 0.22s var(--luma-ease), background 0.22s var(--luma-ease), color 0.22s var(--luma-ease), border-color 0.22s var(--luma-ease);
      }
      .luma-btn--solid { background: var(--luma-ink); color: var(--luma-paper); }
      .luma-btn--solid:hover { transform: translateY(-2px); background: var(--luma-coral); }
      .luma-btn--line { background: transparent; color: var(--luma-ink); border-color: var(--luma-line); }
      .luma-btn--line:hover { transform: translateY(-2px); border-color: var(--luma-coral); color: var(--luma-coral); }

      /* ============ SKIP LINK ============ */
      .luma-skip {
        position: absolute; left: 12px; top: -60px; z-index: 200;
        background: var(--luma-ink); color: var(--luma-paper);
        padding: 0.6em 1em; border-radius: 10px; text-decoration: none;
        transition: top 0.2s var(--luma-ease);
      }
      .luma-skip:focus { top: 12px; }

      /* ============ NAVIGACE ============ */
      .luma-nav {
        position: sticky; top: 0; z-index: 100;
        background: color-mix(in srgb, var(--luma-paper) 86%, transparent);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--luma-line-soft);
      }
      .luma-nav__inner { display: flex; align-items: center; gap: 1rem; height: 72px; }
      .luma-brand { display: inline-flex; align-items: center; gap: 0.55rem; text-decoration: none; color: var(--luma-ink); }
      .luma-brand__mark { display: inline-flex; }
      .luma-brand__name { font-family: var(--luma-ff-display); font-weight: 700; font-size: 1.35rem; letter-spacing: -0.01em; }
      .luma-nav__links { display: flex; gap: 0.3rem; margin-left: auto; }
      .luma-nav__link {
        text-decoration: none; color: var(--luma-ink-soft); font-weight: 500; font-size: 0.96rem;
        padding: 0.5em 0.7em; border-radius: 999px; position: relative;
        transition: color 0.2s var(--luma-ease), background 0.2s var(--luma-ease);
      }
      .luma-nav__link:hover { color: var(--luma-ink); background: var(--luma-paper-2); }
      .luma-nav__link.is-active { color: var(--luma-ink); }
      .luma-nav__link.is-active::after {
        content: ""; position: absolute; left: 0.7em; right: 0.7em; bottom: 0.18em; height: 2.5px;
        border-radius: 2px;
        background: linear-gradient(90deg, var(--luma-coral), var(--luma-copper), var(--luma-magenta));
      }
      .luma-nav__cta { margin-left: 0.6rem; padding: 0.6em 1.1em; }

      .luma-burger {
        display: none; margin-left: auto; width: 44px; height: 44px;
        background: transparent; border: 1px solid var(--luma-line); border-radius: 12px;
        cursor: pointer; padding: 0; flex-direction: column; gap: 5px; align-items: center; justify-content: center;
      }
      .luma-burger span { width: 20px; height: 2px; background: var(--luma-ink); border-radius: 2px; transition: transform 0.25s var(--luma-ease), opacity 0.2s var(--luma-ease); }
      .luma-burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      .luma-burger.is-open span:nth-child(2) { opacity: 0; }
      .luma-burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

      .luma-mobile { border-top: 1px solid var(--luma-line-soft); background: var(--luma-paper); }
      .luma-mobile__nav { display: flex; flex-direction: column; padding: 0.6rem 4vw 1.2rem; gap: 0.15rem; }
      .luma-mobile__link {
        text-decoration: none; color: var(--luma-ink); font-weight: 500; font-size: 1.05rem;
        padding: 0.75em 0.6em; border-radius: 12px;
      }
      .luma-mobile__link.is-active { color: var(--luma-coral); }
      .luma-mobile__cta { margin-top: 0.6rem; justify-content: center; }

      /* ============ SEKCE & RIBBONY ============ */
      .luma-section { padding: clamp(3.5rem, 8vw, 6rem) 0; position: relative; }
      .luma-divider { position: relative; height: 0; overflow: visible; }

      /* ============ HLAVIČKA STRÁNKY (sdílená) ============ */
      .luma-phead { position: relative; padding: clamp(3rem, 7vw, 5.5rem) 0 clamp(2rem, 4vw, 3rem); overflow: hidden; }
      .luma-phead__inner { position: relative; z-index: 1; max-width: 62ch; }
      .luma-phead h1 { font-size: clamp(2.4rem, 5.5vw, 4rem); font-weight: 600; }
      .luma-phead__sub { margin-top: 1.1rem; font-size: 1.15rem; color: var(--luma-ink-soft); max-width: 56ch; }
      .luma-phead__art { position: absolute; right: -30px; top: -10px; width: clamp(220px, 32vw, 380px); height: clamp(200px, 28vw, 300px); opacity: 0.65; pointer-events: none; z-index: 0; }
      @media (max-width: 720px) { .luma-phead__art { opacity: 0.4; right: -60px; } }

      /* signature ribbon příchod */
      .luma-ribbon path { transition: stroke-dashoffset 1.2s var(--luma-ease), opacity 0.8s var(--luma-ease); }

      /* ============ PATIČKA ============ */
      .luma-foot { background: var(--luma-ink); color: var(--luma-paper); margin-top: 2rem; }
      .luma-foot__inner {
        display: grid; grid-template-columns: 1.4fr 1fr 1fr; gap: 2.5rem;
        padding: clamp(3rem, 6vw, 4.5rem) 0 2.5rem;
      }
      .luma-foot__name { color: var(--luma-paper); font-size: 1.5rem; }
      .luma-foot__tag { color: color-mix(in srgb, var(--luma-paper) 72%, transparent); max-width: 36ch; margin: 0.7rem 0 0; }
      .luma-foot__links { display: flex; flex-direction: column; gap: 0.45rem; }
      .luma-foot__link { color: color-mix(in srgb, var(--luma-paper) 78%, transparent); text-decoration: none; width: fit-content; transition: color 0.2s var(--luma-ease); }
      .luma-foot__link:hover { color: var(--luma-copper); }
      .luma-foot__meta { color: color-mix(in srgb, var(--luma-paper) 78%, transparent); }
      .luma-foot__meta p { margin: 0 0 0.4rem; }
      .luma-foot__bottom {
        display: flex; flex-wrap: wrap; gap: 0.6rem 1.5rem; justify-content: space-between;
        padding: 1.4rem 0 2rem; border-top: 1px solid color-mix(in srgb, var(--luma-paper) 16%, transparent);
        font-size: 0.85rem; color: color-mix(in srgb, var(--luma-paper) 64%, transparent);
      }
      .luma-foot__demo { margin: 0; }
      .luma-foot__mossven { color: var(--luma-copper); font-weight: 600; text-decoration: none; }
      .luma-foot__mossven:hover { text-decoration: underline; }
      .luma-foot__year { margin: 0; }

      /* ============ FOCUS (klávesnice) ============ */
      .luma-body a:focus-visible, .luma-body button:focus-visible,
      .luma-body input:focus-visible, .luma-body textarea:focus-visible, .luma-body select:focus-visible {
        outline: 3px solid var(--luma-coral); outline-offset: 3px; border-radius: 6px;
      }

      /* ============ MOTION při načtení ============ */
      .luma-anim { opacity: 0; transform: translateY(18px); transition: opacity 0.7s var(--luma-ease), transform 0.7s var(--luma-ease); }
      .luma-body.luma-ready .luma-anim { opacity: 1; transform: none; }
      .luma-anim[data-delay="1"] { transition-delay: 0.08s; }
      .luma-anim[data-delay="2"] { transition-delay: 0.16s; }
      .luma-anim[data-delay="3"] { transition-delay: 0.24s; }
      .luma-anim[data-delay="4"] { transition-delay: 0.32s; }
      .luma-anim[data-delay="5"] { transition-delay: 0.40s; }

      /* ============ RESPONZIVITA ============ */
      @media (max-width: 920px) {
        .luma-nav__links, .luma-nav__cta { display: none; }
        .luma-burger { display: flex; }
        .luma-foot__inner { grid-template-columns: 1fr 1fr; }
        .luma-foot__brand { grid-column: 1 / -1; }
      }
      @media (max-width: 560px) {
        .luma-foot__inner { grid-template-columns: 1fr; gap: 1.8rem; }
      }

      /* ============ REDUCED MOTION ============ */
      @media (prefers-reduced-motion: reduce) {
        .luma-body * { animation: none !important; transition-duration: 0.001ms !important; }
        .luma-anim { opacity: 1 !important; transform: none !important; }
        .luma-btn:hover { transform: none; }
      }
    </style>
  </body>
</html>
