---
// Ukázkový (demo) web pro fiktivní kavárnu „Kavárna Zrnko".
// Samostatná stránka - vlastní identita, nepoužívá Mossven Layout.
// Záměrně jiná struktura než ostatní ukázky: menu je hlavní obsah.
// Route: /ukazky/kavarna

import { Image } from "astro:assets";

// Fotografie atmosféry, kávy a interiéru (přes astro:assets: automatický webp,
// responzivní velikosti a lazy-loading, ať stránka zůstane svižná).
import heroKava from "./kavarna/kavarna-hero-kava-interier.png";
import fotoEspresso from "./kavarna/kavarna-espresso.png";
import fotoKolac from "./kavarna/kavarna-domaci-kolac.png";
import fotoToast from "./kavarna/kavarna-toast.png";
import fotoZrno from "./kavarna/kavarna-zrno-detail.png";
import fotoInterier from "./kavarna/kavarna-interier.png";
import fotoSalek from "./kavarna/kavarna-salek-detail.png";
import fotoVitrina from "./kavarna/kavarna-vitrina.png";
import fotoVchod from "./kavarna/kavarna-vchod.png";

// Malý fotopruh k menu (neúplný výčet, jen pro atmosféru).
const menuFoto = [
  { img: fotoEspresso, alt: "Šálek espresa s krémovou cremou na dřevěném stole", n: "Espresso" },
  { img: fotoKolac, alt: "Domácí koláč na talířku v útulné kavárně", n: "Domácí koláč" },
  { img: fotoToast, alt: "Avokádový toast naservírovaný k lehkému obědu", n: "Něco k tomu" },
];

const espresso = [
  { n: "Espresso", p: "55" },
  { n: "Doppio", p: "69" },
  { n: "Flat white", p: "75" },
  { n: "Cappuccino", p: "69" },
  { n: "Filtr (V60)", p: "65" },
  { n: "Latte", p: "75" },
];
const ktomu = [
  { n: "Máslový croissant", p: "45" },
  { n: "Cheesecake", p: "79" },
  { n: "Banánový chlebíček", p: "59" },
  { n: "Cookie", p: "39" },
  { n: "Avokádový toast", p: "129" },
];
const hodiny = [
  { d: "Po–Pá", h: "7:30 – 18:00" },
  { d: "Sobota", h: "9:00 – 17:00" },
  { d: "Neděle", h: "9:00 – 15:00" },
];
const galerie = [
  { n: "Interiér", img: fotoInterier, alt: "Útulný interiér kavárny s dřevěnými stoly a měkkým denním světlem" },
  { n: "Šálek", img: fotoSalek, alt: "Detail šálku kávy s mléčnou pěnou na keramickém talířku" },
  { n: "Vitrína", img: fotoVitrina, alt: "Vitrína s domácími dorty a koláči připravenými k podání" },
];
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kavárna Zrnko: káva, co stojí za zastavení</title>
    <meta name="description" content="Malá kavárna s vlastním výběrem zrna. Espresso, filtr a poctivé dobroty. Stavte se na šálek. Ukázkový web od Mossven." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="kv-body">
    <header class="kv-top">
      <div class="kv-wrap kv-top__inner">
        <a class="kv-brand" href="#kv-top" aria-label="Kavárna Zrnko, domů">
          <span class="kv-brand__mark" aria-hidden="true"></span>
          <span class="kv-brand__name">Kavárna&nbsp;Zrnko</span>
        </a>
        <span class="kv-top__hours">Dnes 7:30–18:00</span>
        <a class="kv-btn kv-btn--ghost kv-top__cta" href="#kv-najit">Najít cestu</a>
      </div>
    </header>

    <main id="kv-top">
      <!-- HERO -->
      <section class="kv-hero" aria-labelledby="kv-hero-title">
        <div class="kv-wrap kv-hero__grid">
          <div class="kv-hero__text">
            <p class="kv-eyebrow">Malá kavárna · pražíme po malých dávkách</p>
            <h1 id="kv-hero-title" class="kv-hero__title">Káva, co stojí<br />za zastavení.</h1>
            <p class="kv-hero__sub">
              Vybíráme zrno, které nám chutná, a děláme ho poctivě. Sedněte si na chvíli,
              nebo si vezměte s sebou: espresso, filtr a něco dobrého k tomu.
            </p>
            <div class="kv-hero__cta">
              <a class="kv-btn kv-btn--solid" href="#kv-najit">Stavte se</a>
              <a class="kv-btn kv-btn--line" href="#kv-menu">Zobrazit menu</a>
            </div>
          </div>
          <figure class="kv-herofig">
            <Image
              src={heroKava}
              alt="Šálek kávy na dřevěném stole v útulném interiéru kavárny, měkké ranní světlo"
              widths={[480, 720, 1040, 1400]}
              sizes="(max-width: 880px) 100vw, 520px"
              format="webp"
              quality={74}
              loading="eager"
              decoding="async"
            />
          </figure>
        </div>
      </section>

      <!-- MENU (centerpiece) -->
      <section id="kv-menu" class="kv-menu" aria-labelledby="kv-menu-h">
        <div class="kv-wrap">
          <div class="kv-menu__card">
            <header class="kv-menu__head">
              <h2 id="kv-menu-h">Menu</h2>
              <span class="kv-menu__note">ceny v Kč · platí dnes</span>
            </header>
            <div class="kv-menu__cols">
              <div class="kv-menu__col">
                <h3 class="kv-menu__cat">Espresso bar</h3>
                <ul class="kv-list">
                  {espresso.map((i) => (
                    <li class="kv-row"><span class="kv-row__n">{i.n}</span><span class="kv-row__dots" aria-hidden="true"></span><span class="kv-row__p">{i.p}</span></li>
                  ))}
                </ul>
              </div>
              <div class="kv-menu__col">
                <h3 class="kv-menu__cat">K tomu</h3>
                <ul class="kv-list">
                  {ktomu.map((i) => (
                    <li class="kv-row"><span class="kv-row__n">{i.n}</span><span class="kv-row__dots" aria-hidden="true"></span><span class="kv-row__p">{i.p}</span></li>
                  ))}
                </ul>
                <p class="kv-menu__small">Rostlinné mléko bez příplatku. Sezónní nabídku najdete na tabuli ve dveřích.</p>
              </div>
            </div>
          </div>
          <ul class="kv-menustrip" aria-label="Ukázky z nabídky">
            {menuFoto.map((f) => (
              <li class="kv-menustrip__item">
                <figure class="kv-shot">
                  <Image
                    src={f.img}
                    alt={f.alt}
                    widths={[360, 560, 760]}
                    sizes="(max-width: 600px) 100vw, (max-width: 880px) 50vw, 340px"
                    format="webp"
                    quality={74}
                    loading="lazy"
                    decoding="async"
                  />
                  <figcaption class="kv-shot__cap">{f.n}</figcaption>
                </figure>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- ZRNO -->
      <section class="kv-beans" aria-labelledby="kv-beans-h">
        <div class="kv-wrap kv-beans__inner">
          <figure class="kv-shot kv-beans__photo">
            <Image
              src={fotoZrno}
              alt="Detail kávových zrn a přípravy kávy, mlýnek a páka s mletou kávou"
              widths={[420, 640, 880]}
              sizes="(max-width: 880px) 100vw, 420px"
              format="webp"
              quality={74}
              loading="lazy"
              decoding="async"
            />
          </figure>
          <div>
            <p class="kv-kicker">Naše zrno</p>
            <h2 id="kv-beans-h" class="kv-beans__h">Pražíme po malých dávkách, ať je čerstvé</h2>
            <p class="kv-beans__p">
              Měníme nabídku podle sezóny a podle toho, co zrovna chutná nám. Když nevíte, dáme vám
              ochutnat a poradíme podle toho, jak pijete kávu doma. Zrno si můžete odnést i v balíčku.
            </p>
          </div>
        </div>
      </section>

      <!-- HODINY + NAVŠTÍVIT -->
      <section id="kv-najit" class="kv-visit" aria-labelledby="kv-visit-h">
        <div class="kv-wrap kv-visit__grid">
          <div class="kv-visit__hours">
            <p class="kv-kicker">Otevírací doba</p>
            <h2 id="kv-visit-h" class="kv-visit__h">Kdy máme otevřeno</h2>
            <ul class="kv-hours">
              {hodiny.map((h) => (
                <li class="kv-hours__row"><span>{h.d}</span><span class="kv-hours__h">{h.h}</span></li>
              ))}
            </ul>
          </div>
          <div class="kv-visit__where">
            <p class="kv-kicker">Kde nás najdete</p>
            <p class="kv-visit__addr">Krajinská 9<br />České Budějovice</p>
            <figure class="kv-shot kv-visit__photo">
              <Image
                src={fotoVchod}
                alt="Vchod do kavárny s posezením u okna, útulná uliční fasáda"
                widths={[480, 720, 1000]}
                sizes="(max-width: 880px) 100vw, 520px"
                format="webp"
                quality={74}
                loading="lazy"
                decoding="async"
              />
            </figure>
            <div class="kv-map" role="img" aria-label="Orientační poloha kavárny">
              <svg viewBox="0 0 320 150" aria-hidden="true">
                <rect width="320" height="150" class="kv-map__bg"/>
                <path d="M0 96 H320 M120 0 V150 M0 40 H210" class="kv-map__road"/>
                <circle cx="120" cy="96" r="7" class="kv-map__pin"/>
                <circle cx="120" cy="96" r="2.4" class="kv-map__pindot"/>
              </svg>
            </div>
          </div>
        </div>
      </section>

      <!-- GALERIE -->
      <section class="kv-gallery" aria-labelledby="kv-gallery-h">
        <div class="kv-wrap">
          <header class="kv-ghead">
            <p class="kv-kicker">Ukázky</p>
            <h2 id="kv-gallery-h" class="kv-gallery__h">Jak to u nás vypadá</h2>
            <p class="kv-ghead__lead">Pár záběrů na atmosféru. Nejlíp ji ale poznáte, když se stavíte.</p>
          </header>
          <ul class="kv-gallery__grid">
            {galerie.map((g) => (
              <li class="kv-gcard">
                <div class="kv-gcard__art">
                  <Image
                    class="kv-gcard__photo"
                    src={g.img}
                    alt={g.alt}
                    widths={[400, 600, 800]}
                    sizes="(max-width: 880px) 100vw, 360px"
                    format="webp"
                    quality={74}
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <span class="kv-gcard__n">{g.n}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- KONTAKT -->
      <section class="kv-contact" aria-labelledby="kv-contact-h">
        <div class="kv-wrap">
          <div class="kv-contact__panel">
            <div>
              <p class="kv-kicker kv-kicker--light">Ozvěte se</p>
              <h2 id="kv-contact-h" class="kv-contact__h">Rezervace, dort na objednávku nebo jen dotaz?</h2>
              <p class="kv-contact__lead">Napište nebo zavolejte. Na větší skupinu i dort na objednávku se rádi domluvíme dopředu.</p>
            </div>
            <div class="kv-contact__details">
              <a class="kv-crow" href="tel:+420777456789"><span class="kv-crow__l">Telefon</span><span class="kv-crow__v">+420 777 456 789</span></a>
              <a class="kv-crow" href="mailto:kavarna.zrnko@example.cz"><span class="kv-crow__l">E-mail</span><span class="kv-crow__v">kavarna.zrnko@example.cz</span></a>
              <a class="kv-btn kv-btn--solid kv-contact__btn" href="tel:+420777456789">Zavolat</a>
              <p class="kv-contact__demo">Demo ukázka webu od Mossven.</p>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="kv-foot">
      <div class="kv-wrap kv-foot__inner">
        <div>
          <span class="kv-brand__name">Kavárna Zrnko</span>
          <p class="kv-foot__tag">Malá kavárna s vlastním výběrem zrna.</p>
        </div>
        <p class="kv-foot__note">Demo web vytvořený jako ukázka řešení od <a class="kv-foot__link" href="/">Mossven</a>.</p>
      </div>
    </footer>

    <style is:global>
      /* Kavárna Zrnko - samostatná demo stránka, vše prefixováno .kv- */
      .kv-body {
        --kv-cream: #f4ecdc; --kv-cream-2: #ece0cb; --kv-panel: #fbf5ea;
        --kv-espresso: #271a11; --kv-soft: #6f5a47; --kv-faint: #9b8a76;
        --kv-crema: #cf9a52; --kv-clay: #bb472a; --kv-line: rgba(39,26,17,.14); --kv-line-soft: rgba(39,26,17,.07);
        --ff-display: "Bricolage Grotesque", system-ui, sans-serif;
        --ff-body: "Instrument Sans", system-ui, sans-serif;
        --kv-ease: cubic-bezier(.22,.61,.36,1); --kv-maxw: 1140px;
        margin: 0; font-family: var(--ff-body); color: var(--kv-espresso);
        background-color: var(--kv-cream);
        background-image: radial-gradient(1100px 600px at 82% -16%, rgba(207,154,82,.16), transparent 60%);
        line-height: 1.6; -webkit-font-smoothing: antialiased; overflow-x: hidden;
      }
      .kv-body *, .kv-body *::before, .kv-body *::after { box-sizing: border-box; }
      .kv-wrap { max-width: var(--kv-maxw); margin: 0 auto; padding: 0 26px; }
      .kv-body a:not(.kv-btn) { color: inherit; }
      .kv-body a { text-decoration: none; }
      .kv-body h1, .kv-body h2, .kv-body h3 { font-family: var(--ff-display); margin: 0; line-height: 1.02; letter-spacing: -.02em; font-weight: 700; }
      .kv-body p { margin: 0; }
      .kv-kicker { font-family: var(--ff-body); font-size: .72rem; font-weight: 600; letter-spacing: .18em; text-transform: uppercase; color: var(--kv-clay); }
      .kv-kicker--light { color: var(--kv-crema); }
      .kv-body a:focus-visible, .kv-body button:focus-visible { outline: 3px solid var(--kv-clay); outline-offset: 3px; border-radius: 3px; }

      .kv-btn { display: inline-flex; align-items: center; justify-content: center; font-family: var(--ff-display); font-weight: 600; font-size: .95rem; padding: .85em 1.5em; border-radius: 999px; cursor: pointer; border: 2px solid transparent; transition: transform .16s var(--kv-ease), background-color .2s, color .2s; }
      .kv-btn--solid { background: var(--kv-clay); color: #fdf3ea; }
      .kv-btn--solid:hover { transform: translateY(-2px); background: #a83d22; }
      .kv-btn--line { background: transparent; color: var(--kv-espresso); border-color: var(--kv-espresso); }
      .kv-btn--line:hover { background: var(--kv-espresso); color: var(--kv-cream); transform: translateY(-2px); }
      .kv-btn--ghost { background: transparent; color: var(--kv-espresso); border-color: var(--kv-line); font-size: .84rem; padding: .6em 1.05em; }
      .kv-btn--ghost:hover { border-color: var(--kv-clay); color: var(--kv-clay); }

      .kv-top { position: sticky; top: 0; z-index: 30; background: color-mix(in srgb, var(--kv-cream) 86%, transparent); backdrop-filter: blur(9px); border-bottom: 1px solid var(--kv-line-soft); }
      .kv-top__inner { display: flex; align-items: center; gap: 18px; height: 62px; }
      .kv-brand { display: inline-flex; align-items: center; gap: .55em; }
      .kv-brand__mark { width: 20px; height: 20px; border-radius: 50%; flex: none; background: radial-gradient(circle at 36% 30%, var(--kv-crema), var(--kv-clay) 75%); box-shadow: inset 0 0 0 2px var(--kv-cream); }
      .kv-brand__name { font-family: var(--ff-display); font-weight: 800; font-size: 1.16rem; letter-spacing: -.01em; }
      .kv-top__hours { font-size: .74rem; letter-spacing: .04em; color: var(--kv-soft); padding-left: 18px; border-left: 1px solid var(--kv-line); }
      .kv-top__cta { margin-left: auto; }

      /* HERO */
      .kv-hero { padding: clamp(40px,6vw,84px) 0 clamp(36px,5vw,68px); }
      .kv-hero__grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: clamp(28px,4vw,56px); align-items: center; }
      .kv-eyebrow { font-size: .8rem; font-weight: 600; letter-spacing: .04em; color: var(--kv-soft); margin-bottom: 1.1rem; }
      .kv-hero__title { font-size: clamp(2.6rem,7vw,4.7rem); font-weight: 800; line-height: .98; }
      .kv-hero__sub { margin-top: 1.3rem; font-size: clamp(1.04rem,1.5vw,1.2rem); color: var(--kv-soft); max-width: 30em; }
      .kv-hero__cta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 1.9rem; }

      /* MENU */
      .kv-menu { padding: clamp(30px,4vw,60px) 0; }
      .kv-menu__card { background: var(--kv-panel); border: 1px solid var(--kv-line); border-radius: 16px; padding: clamp(26px,4vw,52px); box-shadow: 0 30px 60px -38px rgba(39,26,17,.5); position: relative; }
      .kv-menu__card::before { content: ""; position: absolute; inset: 10px; border: 1px solid var(--kv-line-soft); border-radius: 10px; pointer-events: none; }
      .kv-menu__head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin-bottom: 20px; }
      .kv-menu__head h2 { font-size: clamp(2rem,4vw,3rem); }
      .kv-menu__note { font-size: .72rem; letter-spacing: .14em; text-transform: uppercase; color: var(--kv-soft); }
      .kv-menu__cols { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(28px,5vw,72px); position: relative; }
      .kv-menu__cat { font-size: 1.15rem; color: var(--kv-clay); margin-bottom: 10px; }
      .kv-list { list-style: none; margin: 0; padding: 0; }
      .kv-row { display: flex; align-items: baseline; gap: 8px; padding: 9px 0; border-bottom: 1px solid var(--kv-line-soft); }
      .kv-row__n { font-weight: 500; }
      .kv-row__dots { flex: 1; border-bottom: 2px dotted var(--kv-line); transform: translateY(-3px); }
      .kv-row__p { font-family: var(--ff-display); font-weight: 700; font-variant-numeric: tabular-nums; }
      .kv-menu__small { margin-top: 14px; font-size: .86rem; color: var(--kv-soft); }

      /* ZRNO */
      .kv-beans { padding: clamp(44px,6vw,84px) 0; }
      .kv-beans__inner { display: grid; grid-template-columns: auto 1fr; gap: clamp(20px,3vw,40px); align-items: center; max-width: 60rem; }
      .kv-beans__h { font-size: clamp(1.6rem,3.2vw,2.4rem); margin-top: .7rem; }
      .kv-beans__p { margin-top: 1rem; color: var(--kv-soft); font-size: 1.04rem; }

      /* VISIT */
      .kv-visit { padding: clamp(44px,6vw,84px) 0; }
      .kv-visit__grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(24px,4vw,52px); }
      .kv-visit__h, .kv-gallery__h, .kv-contact__h { font-size: clamp(1.6rem,3.2vw,2.4rem); margin-top: .7rem; }
      .kv-hours { list-style: none; margin: 1.2rem 0 0; padding: 0; }
      .kv-hours__row { display: flex; justify-content: space-between; padding: 13px 0; border-bottom: 1px solid var(--kv-line-soft); font-size: 1.05rem; }
      .kv-hours__h { font-family: var(--ff-display); font-weight: 700; }
      .kv-visit__addr { font-family: var(--ff-display); font-weight: 700; font-size: 1.5rem; margin-top: .9rem; line-height: 1.15; }
      .kv-map { margin-top: 1.1rem; border: 1px solid var(--kv-line); border-radius: 12px; overflow: hidden; }
      .kv-map svg { display: block; width: 100%; height: auto; }
      .kv-map__bg { fill: var(--kv-cream-2); }
      .kv-map__road { fill: none; stroke: var(--kv-line); stroke-width: 6; }
      .kv-map__pin { fill: var(--kv-clay); }
      .kv-map__pindot { fill: var(--kv-panel); }

      /* GALERIE */
      .kv-gallery { padding: clamp(44px,6vw,84px) 0; }
      .kv-ghead { max-width: 40rem; margin: 0 auto clamp(24px,3vw,40px); text-align: center; }
      .kv-ghead__lead { margin-top: .8rem; color: var(--kv-soft); }
      .kv-gallery__grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
      .kv-gcard { background: var(--kv-panel); border: 1px solid var(--kv-line); border-radius: 14px; overflow: hidden; transition: transform .2s var(--kv-ease); }
      .kv-gcard:hover { transform: translateY(-4px); }
      .kv-gcard__art { aspect-ratio: 4/3; overflow: hidden; background: linear-gradient(160deg, var(--kv-cream), var(--kv-cream-2)); border-bottom: 1px solid var(--kv-line-soft); }
      .kv-gcard__n { display: block; padding: 12px 16px; font-family: var(--ff-display); font-weight: 700; }

      /* CONTACT */
      .kv-contact { padding: clamp(20px,3vw,40px) 0 clamp(50px,6vw,90px); }
      .kv-contact__panel { display: grid; grid-template-columns: 1.1fr .9fr; gap: clamp(26px,4vw,52px); background: var(--kv-espresso); color: var(--kv-cream); border-radius: 22px; padding: clamp(28px,4vw,52px); }
      .kv-contact__h { color: #fbf3e8; }
      .kv-contact__lead { margin-top: 1rem; color: #d8c6b1; max-width: 26em; }
      .kv-contact__details { display: flex; flex-direction: column; gap: 12px; justify-content: center; }
      .kv-crow { display: flex; flex-direction: column; gap: 2px; padding: 14px 16px; border: 1px solid rgba(244,236,220,.18); border-radius: 12px; transition: border-color .2s, background-color .2s; }
      .kv-crow:hover { border-color: var(--kv-crema); background: rgba(244,236,220,.05); }
      .kv-crow__l { font-size: .66rem; letter-spacing: .16em; text-transform: uppercase; color: var(--kv-crema); }
      .kv-crow__v { font-family: var(--ff-display); font-weight: 700; font-size: 1.16rem; }
      .kv-contact__btn { margin-top: 4px; }
      .kv-contact__demo { color: #b59c82; font-size: .78rem; margin-top: 6px; }

      /* FOOTER */
      .kv-foot { border-top: 1px solid var(--kv-line); padding: 32px 0; }
      .kv-foot__inner { display: flex; flex-wrap: wrap; gap: 16px 28px; align-items: center; justify-content: space-between; }
      .kv-foot__tag { color: var(--kv-soft); font-size: .92rem; margin-top: 2px; }
      .kv-foot__note { color: var(--kv-soft); font-size: .92rem; }
      .kv-foot__link { color: var(--kv-clay); font-weight: 600; border-bottom: 2px solid var(--kv-clay); }

      /* FOTOGRAFIE (sdílené) */
      .kv-shot { position: relative; margin: 0; overflow: hidden; background: var(--kv-panel); border: 1px solid var(--kv-line); border-radius: 14px; box-shadow: 0 20px 40px -30px rgba(39,26,17,.5); }
      .kv-shot img { display: block; width: 100%; height: 100%; object-fit: cover; aspect-ratio: 4/3; }
      .kv-shot__cap { position: absolute; left: 10px; bottom: 10px; font-family: var(--ff-display); font-weight: 700; font-size: .78rem; color: var(--kv-espresso); background: rgba(251,245,234,.88); -webkit-backdrop-filter: blur(2px); backdrop-filter: blur(2px); padding: 4px 10px; border-radius: 999px; border: 1px solid var(--kv-line-soft); }

      /* HERO foto (nahrazuje ilustrovaný šálek) */
      .kv-herofig { margin: 0; border-radius: 18px; overflow: hidden; border: 1px solid var(--kv-line); box-shadow: 0 36px 70px -40px rgba(39,26,17,.6); transform: rotate(-.6deg); }
      .kv-herofig img { display: block; width: 100%; height: auto; aspect-ratio: 5/4; object-fit: cover; }

      /* MENU fotopruh */
      .kv-menustrip { list-style: none; margin: clamp(18px,2.5vw,28px) 0 0; padding: 0; display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; }
      .kv-menustrip__item { margin: 0; }
      .kv-menustrip .kv-shot img { aspect-ratio: 1/1; }

      /* ZRNO foto */
      .kv-beans__inner { grid-template-columns: .82fr 1.18fr; max-width: 64rem; }
      .kv-beans__photo img { aspect-ratio: 4/3; }

      /* GALERIE foto */
      .kv-gcard__photo { width: 100%; height: 100%; object-fit: cover; display: block; }

      /* VCHOD foto u lokality */
      .kv-visit__photo { margin-top: 1.1rem; border-radius: 12px; }
      .kv-visit__photo img { aspect-ratio: 16/10; }

      @media (max-width: 880px) {
        .kv-hero__grid { grid-template-columns: 1fr; }
        .kv-herofig { order: -1; transform: none; max-width: 480px; margin-inline: auto; }
        .kv-menustrip { grid-template-columns: repeat(3,1fr); }
        .kv-beans__photo { max-width: 480px; }
        .kv-menu__cols { grid-template-columns: 1fr; gap: 28px; }
        .kv-visit__grid { grid-template-columns: 1fr; }
        .kv-gallery__grid { grid-template-columns: 1fr; max-width: 420px; margin-inline: auto; }
        .kv-contact__panel { grid-template-columns: 1fr; }
        .kv-beans__inner { grid-template-columns: 1fr; }
      }
      @media (max-width: 600px) { .kv-top__hours { display: none; } .kv-foot__inner { flex-direction: column; align-items: flex-start; } }
      @media (prefers-reduced-motion: reduce) { .kv-body * { animation: none !important; transition: none !important; } }
    </style>
  </body>
