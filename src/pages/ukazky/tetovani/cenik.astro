---
import Hrot from "./_layout/Hrot.astro";
import Needle from "./_layout/Needle.astro";

const base = "/ukazky/tetovani";

const tattoo = [
  { t: "Konzultace", v: "zdarma", note: "podle rozsahu" },
  { t: "Malý motiv", v: "od 1 500 Kč", note: "do dlaně" },
  { t: "Jemné linky", v: "od 1 800 Kč", note: "fine-line" },
  { t: "Střední motiv", v: "od 3 500 Kč", note: "předloktí, lýtko" },
  { t: "Větší práce", v: "individuálně", note: "rukáv, záda, na sezení" },
  { t: "Úprava návrhu", v: "podle domluvy", note: "překrytí, doplnění" },
];

const piercing = [
  { t: "Ušní lalůček", v: "od 700 Kč", note: "vč. základního šperku" },
  { t: "Helix / tragus / conch", v: "od 900 Kč", note: "titanový šperk" },
  { t: "Nos", v: "od 900 Kč", note: "nostril" },
  { t: "Obočí / ret", v: "od 1 000 Kč", note: "" },
  { t: "Pupík", v: "od 1 100 Kč", note: "" },
  { t: "Šperk", v: "podle typu", note: "materiál a velikost" },
];

const notes = [
  "Přesná cena závisí na velikosti, umístění, detailu a délce práce.",
  "U tetování se finální cena potvrzuje po konzultaci.",
  "Používáme sterilní materiál a kvalitní šperky vhodné pro první aplikaci.",
  "Ceny jsou ukázkové pro demo web.",
];
---

<Hrot
  title="Ceník — Ateliér Hrot"
  description="Orientační ceník tetování a piercingu v ateliéru Hrot. Malý motiv od 1 500 Kč, jemné linky od 1 800 Kč, piercing ucha od 700 Kč. Finální cena u tetování po konzultaci. Ukázkové ceny, demo web od Mossven."
  active="cenik"
>
  <header class="hr-phead hr-grid-tex is-dark">
    <span class="hr-phead__num" aria-hidden="true">03</span>
    <div class="hr-wrap hr-phead__inner">
      <p class="hr-label hr-anim is-in">Sazebník · ukázka</p>
      <h1 class="hr-anim is-in" data-delay="1">Ceník</h1>
      <p class="hr-phead__sub hr-anim is-in" data-delay="2">
        Orientační ceny, ze kterých vyjdeme. U tetování se finální částka
        potvrzuje až po konzultaci, podle velikosti, umístění a délky práce.
      </p>
    </div>
  </header>

  <section class="hr-section is-bone hr-rate" aria-label="Ceník">
    <div class="hr-wrap">
      <div class="hr-rate__sheet hr-anim">
        <!-- záhlaví listu -->
        <div class="hr-rate__masthead">
          <span class="hr-mono hr-rate__id">ATELIÉR HROT — SAZEBNÍK</span>
          <span class="hr-mono hr-rate__rev">rev. demo · Kč</span>
        </div>

        <div class="hr-rate__cols">
          <!-- TETOVÁNÍ -->
          <div class="hr-rate__col">
            <header class="hr-rate__colhead">
              <h2>Tetování</h2>
              <span class="hr-mono hr-rate__tag">A</span>
            </header>
            <dl class="hr-rate__items">
              {tattoo.map((it) => (
                <div class="hr-rate__item">
                  <dt class="hr-rate__name">
                    {it.t}
                    {it.note && <span class="hr-rate__note">{it.note}</span>}
                  </dt>
                  <span class="hr-rate__dots" aria-hidden="true"></span>
                  <dd class="hr-mono hr-rate__price">{it.v}</dd>
                </div>
              ))}
            </dl>
          </div>

          <!-- PIERCING -->
          <div class="hr-rate__col">
            <header class="hr-rate__colhead">
              <h2>Piercing</h2>
              <span class="hr-mono hr-rate__tag">B</span>
            </header>
            <dl class="hr-rate__items">
              {piercing.map((it) => (
                <div class="hr-rate__item">
                  <dt class="hr-rate__name">
                    {it.t}
                    {it.note && <span class="hr-rate__note">{it.note}</span>}
                  </dt>
                  <span class="hr-rate__dots" aria-hidden="true"></span>
                  <dd class="hr-mono hr-rate__price">{it.v}</dd>
                </div>
              ))}
            </dl>
          </div>
        </div>

        <div class="hr-rate__needle" aria-hidden="true"><Needle variant="divider" /></div>

        <!-- POZNÁMKY -->
        <div class="hr-rate__notes">
          <span class="hr-mono hr-rate__noteshead">Poznámky k sazebníku</span>
          <ul>
            {notes.map((n, i) => (
              <li><span class="hr-mono hr-rate__noteidx">{String(i + 1).padStart(2, "0")}</span>{n}</li>
            ))}
          </ul>
        </div>
      </div>

      <div class="hr-rate__cta hr-anim" data-delay="1">
        <p>Chcete odhad pro konkrétní motiv?</p>
        <a class="hr-btn hr-btn--solid" href={`${base}/kontakt`}>Domluvit konzultaci <span class="hr-btn__arrow">→</span></a>
      </div>
    </div>
  </section>

  <style>
    .hr-phead h1 { font-size: clamp(3rem, 12vw, 8rem); }

    .hr-rate__sheet {
      background: #F4ECDF; border: 1px solid var(--hr-on-bone);
      border-radius: var(--hr-r); padding: clamp(1.4rem, 3.5vw, 2.6rem);
      box-shadow: 0 40px 80px -50px rgba(42,37,32,0.6);
      position: relative;
    }
    .hr-rate__masthead { display: flex; justify-content: space-between; align-items: center; gap: 1rem; padding-bottom: 1rem; border-bottom: 2px solid var(--hr-on-bone); margin-bottom: 2rem; flex-wrap: wrap; }
    .hr-rate__id { font-size: 0.74rem; letter-spacing: 0.18em; color: var(--hr-on-bone); }
    .hr-rate__rev { font-size: 0.7rem; color: var(--hr-on-bone-soft); }

    .hr-rate__cols { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1.5rem, 4vw, 3.5rem); }
    .hr-rate__col {}
    .hr-rate__colhead { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1rem; }
    .hr-rate__colhead h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); }
    .hr-rate__tag { font-size: 0.7rem; color: var(--hr-ink); background: var(--hr-amber); padding: 0.25em 0.6em; border-radius: 2px; }

    .hr-rate__items { margin: 0; }
    .hr-rate__item { display: grid; grid-template-columns: auto 1fr auto; align-items: baseline; gap: 0.5rem; padding: 0.85rem 0; }
    .hr-rate__name { font-family: var(--hr-ff-display); font-weight: 600; font-size: 1.12rem; margin: 0; color: var(--hr-on-bone); display: flex; flex-direction: column; }
    .hr-rate__note { font-family: var(--hr-ff-body); font-weight: 400; font-size: 0.76rem; color: var(--hr-on-bone-soft); letter-spacing: 0; margin-top: 0.1rem; }
    .hr-rate__dots { border-bottom: 1px dotted color-mix(in srgb, var(--hr-on-bone) 45%, transparent); transform: translateY(-0.3rem); }
    .hr-rate__price { font-size: 0.95rem; font-weight: 600; color: var(--hr-amber); white-space: nowrap; }

    .hr-rate__needle { margin: 1.5rem 0; color: var(--hr-amber); }

    .hr-rate__notes { }
    .hr-rate__noteshead { display: block; font-size: 0.68rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--hr-on-bone-soft); margin-bottom: 0.9rem; }
    .hr-rate__notes ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.6rem; }
    .hr-rate__notes li { display: flex; gap: 0.8em; font-size: 0.92rem; color: var(--hr-on-bone-soft); align-items: baseline; }
    .hr-rate__noteidx { font-size: 0.68rem; color: var(--hr-amber); flex: none; }

    .hr-rate__cta { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; margin-top: 2.2rem; flex-wrap: wrap; }
    .hr-rate__cta p { margin: 0; font-family: var(--hr-ff-display); font-weight: 600; font-size: clamp(1.3rem, 2.6vw, 1.8rem); color: var(--hr-on-bone); }

    @media (max-width: 720px) {
      .hr-rate__cols { grid-template-columns: 1fr; gap: 2.4rem; }
    }
  </style>
</Hrot>
