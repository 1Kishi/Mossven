---
// Sdílený layout ukázkového vícestránkového webu fiktivního tetovacího
// a piercing ateliéru „Ateliér Hrot". Samostatná identita — nepoužívá
// Mossven Layout. Všechny třídy mají prefix `hr-`, aby nekolidovaly s
// globálními styly Mossven webu. Složka `_layout` (podtržítko) = neroutuje se.
//
// Identita: ostrá, atmosférická, editorial, lehce underground, ale klinicky
// čistá. Kontrast syrové tetovací kultury a sterilní hygieny. Tmavé editorial
// zóny střídají kostěné (bone) portfolio a ocelové (steel) klinické sekce.

interface Props {
  title: string;
  description: string;
  active: "uvod" | "portfolio" | "sluzby" | "cenik" | "hygiena" | "pece" | "kontakt";
}
const { title, description, active } = Astro.props;

const base = "/ukazky/tetovani";
const nav = [
  { key: "uvod", label: "Úvod", href: `${base}`, idx: "00" },
  { key: "portfolio", label: "Portfolio", href: `${base}/portfolio`, idx: "01" },
  { key: "sluzby", label: "Služby", href: `${base}/sluzby`, idx: "02" },
  { key: "cenik", label: "Ceník", href: `${base}/cenik`, idx: "03" },
  { key: "hygiena", label: "Hygiena", href: `${base}/hygiena`, idx: "04" },
  { key: "pece", label: "Péče", href: `${base}/pece`, idx: "05" },
  { key: "kontakt", label: "Kontakt", href: `${base}/kontakt`, idx: "06" },
];
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="hr-body">
    <a class="hr-skip" href="#hr-main">Přeskočit na obsah</a>

    <div class="hr-progress" id="hr-progress" aria-hidden="true"></div>

    <header class="hr-nav" id="hr-top">
      <div class="hr-wrap hr-nav__inner">
        <a class="hr-brand" href={base} aria-label="Ateliér Hrot: úvod">
          <span class="hr-brand__mark" aria-hidden="true">
            <svg viewBox="0 0 32 32" width="30" height="30" fill="none">
              <circle cx="16" cy="7" r="4.2" stroke="var(--hr-amber)" stroke-width="2" />
              <line x1="16" y1="11" x2="16" y2="24" stroke="var(--hr-bone)" stroke-width="2" />
              <path d="M16 24 L11 32 L21 32 Z" fill="var(--hr-amber)" />
            </svg>
          </span>
          <span class="hr-brand__name">ATELIÉR&nbsp;HROT</span>
        </a>

        <nav class="hr-nav__links" aria-label="Hlavní navigace">
          {nav.map((n) => (
            <a
              href={n.href}
              class:list={["hr-nav__link", { "is-active": active === n.key }]}
              aria-current={active === n.key ? "page" : undefined}
            >
              <span class="hr-nav__idx">{n.idx}</span>{n.label}
            </a>
          ))}
        </nav>

        <a class="hr-btn hr-btn--solid hr-nav__cta" href={`${base}/kontakt`}>Domluvit konzultaci</a>

        <button class="hr-burger" type="button" aria-expanded="false" aria-controls="hr-mobile" aria-label="Otevřít menu">
          <span></span><span></span><span></span>
        </button>
      </div>

      <div class="hr-mobile" id="hr-mobile" hidden>
        <nav class="hr-mobile__nav" aria-label="Mobilní navigace">
          {nav.map((n) => (
            <a
              href={n.href}
              class:list={["hr-mobile__link", { "is-active": active === n.key }]}
              aria-current={active === n.key ? "page" : undefined}
            >
              <span class="hr-mobile__idx">{n.idx}</span>{n.label}
            </a>
          ))}
          <a class="hr-btn hr-btn--solid hr-mobile__cta" href={`${base}/kontakt`}>Domluvit konzultaci</a>
        </nav>
      </div>
    </header>

    <main id="hr-main">
      <slot />
    </main>

    <footer class="hr-foot">
      <div class="hr-wrap hr-foot__top">
        <div class="hr-foot__brand">
          <span class="hr-foot__name">ATELIÉR&nbsp;HROT</span>
          <p class="hr-foot__tag">Autorské tetování, piercing a konzultace. Ostré linky, čistá práce, bezpečný průběh. Lokální ateliér v Brně.</p>
          <div class="hr-foot__sig" aria-hidden="true">
            <svg viewBox="0 0 200 40" fill="none"><path d="M4 28 C 40 8, 70 34, 110 18 S 168 10, 188 22" stroke="var(--hr-amber)" stroke-width="1.5" stroke-linecap="round"/><path d="M188 22 L200 20 L196 26 Z" fill="var(--hr-amber)"/></svg>
          </div>
        </div>

        <nav class="hr-foot__col" aria-label="Navigace v patičce">
          <span class="hr-foot__k">Index</span>
          {nav.map((n) => (
            <a href={n.href} class="hr-foot__link"><span class="hr-foot__idx">{n.idx}</span>{n.label}</a>
          ))}
        </nav>

        <div class="hr-foot__col">
          <span class="hr-foot__k">Ateliér</span>
          <p class="hr-foot__line">Kožešnická 7, Brno</p>
          <p class="hr-foot__line">út–so · jen na objednání</p>
          <p class="hr-foot__line">+420 770 118 240</p>
          <p class="hr-foot__line">atelier.hrot@example.cz</p>
          <p class="hr-foot__line">@atelier.hrot</p>
        </div>
      </div>

      <div class="hr-wrap hr-foot__bottom">
        <p class="hr-foot__demo">Demo web jako ukázka řešení od <a href="/" class="hr-foot__moss">Mossven</a>.</p>
        <p class="hr-foot__legal">© <span id="hr-yr"></span> Ateliér Hrot — ukázka · ceny a údaje jsou smyšlené</p>
      </div>
    </footer>

    <script>
      const yr = document.getElementById("hr-yr");
      if (yr) yr.textContent = String(new Date().getFullYear());

      // Mobilní menu
      const burger = document.querySelector(".hr-burger");
      const mobile = document.getElementById("hr-mobile");
      if (burger && mobile) {
        burger.addEventListener("click", () => {
          const open = burger.getAttribute("aria-expanded") === "true";
          burger.setAttribute("aria-expanded", String(!open));
          burger.classList.toggle("is-open", !open);
          mobile.hidden = open;
        });
      }

      // Hrotová linka jako ukazatel scrollu (tenký akcent nahoře)
      const prog = document.getElementById("hr-progress");
      if (prog) {
        const onScroll = () => {
          const h = document.documentElement;
          const max = h.scrollHeight - h.clientHeight;
          const p = max > 0 ? h.scrollTop / max : 0;
          prog.style.transform = `scaleX(${p})`;
        };
        document.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      }

      // Odhalení obsahu při scrollu
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const items = document.querySelectorAll(".hr-anim");
      if (reduce || !("IntersectionObserver" in window)) {
        items.forEach((el) => el.classList.add("is-in"));
      } else {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add("is-in"); io.unobserve(e.target); }
          });
        }, { threshold: 0.12, rootMargin: "0px 0px -8% 0px" });
        items.forEach((el) => io.observe(el));
      }
      requestAnimationFrame(() => document.body.classList.add("hr-ready"));
    </script>

    <style is:global>
      /* ============ RESET ============ */
      .hr-body *, .hr-body *::before, .hr-body *::after { box-sizing: border-box; }
      .hr-body { margin: 0; }

      /* ============ TOKENY ============ */
      :root {
        --hr-ink: #11100E;
        --hr-ink-2: #1A1815;
        --hr-shadow-paper: #2A2520;
        --hr-bone: #E8DED0;
        --hr-bone-2: #DDD1BF;
        --hr-steel: #A7AAA6;
        --hr-steel-2: #C3C6C1;
        --hr-purple: #5E4B8B;
        --hr-amber: #C47A2C;
        --hr-amber-soft: #D8954A;
        --hr-blood: #7B1E24;

        --hr-ink-soft: #B7AE9F;     /* světlý text na tmavém */
        --hr-ink-faint: #7C766C;
        --hr-on-bone: #2A2520;      /* tmavý text na kostěném */
        --hr-on-bone-soft: #5C544A;

        --hr-line-d: rgba(232, 222, 208, 0.16);   /* linky na tmavém */
        --hr-line-b: rgba(42, 37, 32, 0.16);      /* linky na kostěném */

        --hr-ff-display: "Bricolage Grotesque", "Arial Narrow", sans-serif;
        --hr-ff-body: "IBM Plex Sans", system-ui, -apple-system, sans-serif;
        --hr-ff-mono: "IBM Plex Mono", "SFMono-Regular", ui-monospace, monospace;

        --hr-maxw: 1240px;
        --hr-r: 3px;
        --hr-ease: cubic-bezier(0.2, 0.6, 0.2, 1);
      }

      /* ============ BODY / ATMOSFÉRA ============ */
      .hr-body {
        font-family: var(--hr-ff-body);
        color: var(--hr-bone);
        background: var(--hr-ink);
        line-height: 1.62;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        overflow-x: hidden;
      }
      .hr-wrap { width: min(var(--hr-maxw), 92vw); margin-inline: auto; }

      a { color: inherit; }
      img { max-width: 100%; display: block; }

      /* ============ TYPOGRAFIE ============ */
      .hr-body h1, .hr-body h2, .hr-body h3, .hr-body h4 {
        font-family: var(--hr-ff-display);
        font-weight: 800;
        line-height: 0.98;
        letter-spacing: -0.02em;
        margin: 0;
      }
      .hr-display {
        font-family: var(--hr-ff-display);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 0.92;
      }
      /* technický popisek (mono) */
      .hr-label {
        font-family: var(--hr-ff-mono);
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--hr-amber);
        display: inline-flex; align-items: center; gap: 0.6em;
      }
      .hr-label::before {
        content: ""; width: 22px; height: 1px; background: currentColor; flex: none;
      }
      .hr-label--bare::before { display: none; }
      .hr-lede { font-size: clamp(1.05rem, 1.6vw, 1.22rem); color: var(--hr-ink-soft); max-width: 58ch; }

      .hr-mono { font-family: var(--hr-ff-mono); }

      /* ============ TLAČÍTKA ============ */
      .hr-btn {
        display: inline-flex; align-items: center; gap: 0.6em;
        font-family: var(--hr-ff-mono); font-weight: 500; font-size: 0.84rem;
        letter-spacing: 0.06em;
        padding: 0.95em 1.5em; border-radius: var(--hr-r);
        border: 1px solid transparent; text-decoration: none; cursor: pointer;
        line-height: 1; position: relative; overflow: hidden;
        transition: transform 0.2s var(--hr-ease), background 0.2s var(--hr-ease), color 0.2s var(--hr-ease), border-color 0.2s var(--hr-ease);
      }
      .hr-btn--solid { background: var(--hr-amber); color: var(--hr-ink); }
      .hr-btn--solid:hover { background: var(--hr-amber-soft); transform: translateY(-2px); }
      .hr-btn--ghost { background: transparent; color: var(--hr-bone); border-color: var(--hr-line-d); }
      .hr-btn--ghost:hover { border-color: var(--hr-amber); color: var(--hr-amber); transform: translateY(-2px); }
      .hr-btn--dark { background: var(--hr-ink); color: var(--hr-bone); }
      .hr-btn--dark:hover { background: var(--hr-shadow-paper); transform: translateY(-2px); }
      /* na kostěném pozadí */
      .is-bone .hr-btn--ghost, .is-steel .hr-btn--ghost { color: var(--hr-on-bone); border-color: var(--hr-line-b); }
      .is-bone .hr-btn--ghost:hover, .is-steel .hr-btn--ghost:hover { border-color: var(--hr-amber); color: var(--hr-amber); }
      .hr-btn__arrow { transition: transform 0.2s var(--hr-ease); }
      .hr-btn:hover .hr-btn__arrow { transform: translateX(3px); }

      /* ============ SKIP / PROGRESS ============ */
      .hr-skip {
        position: absolute; left: 12px; top: -60px; z-index: 300;
        background: var(--hr-amber); color: var(--hr-ink); font-family: var(--hr-ff-mono);
        padding: 0.6em 1em; border-radius: var(--hr-r); text-decoration: none; font-size: 0.85rem;
        transition: top 0.2s var(--hr-ease);
      }
      .hr-skip:focus { top: 12px; }
      .hr-progress {
        position: fixed; top: 0; left: 0; right: 0; height: 2px; z-index: 200;
        background: linear-gradient(90deg, var(--hr-amber), var(--hr-blood));
        transform: scaleX(0); transform-origin: 0 50%;
      }

      /* ============ NAVIGACE ============ */
      .hr-nav {
        position: sticky; top: 0; z-index: 100;
        background: color-mix(in srgb, var(--hr-ink) 88%, transparent);
        backdrop-filter: blur(10px) saturate(1.2);
        border-bottom: 1px solid var(--hr-line-d);
      }
      .hr-nav__inner { display: flex; align-items: center; gap: 1.2rem; height: 76px; }
      .hr-brand { display: inline-flex; align-items: center; gap: 0.6rem; text-decoration: none; color: var(--hr-bone); }
      .hr-brand__mark { display: inline-flex; }
      .hr-brand__name { font-family: var(--hr-ff-display); font-weight: 800; font-size: 1.12rem; letter-spacing: 0.02em; }
      .hr-nav__links { display: flex; gap: 0.1rem; margin-left: auto; }
      .hr-nav__link {
        text-decoration: none; color: var(--hr-ink-soft);
        font-family: var(--hr-ff-mono); font-weight: 500; font-size: 0.82rem; letter-spacing: 0.02em;
        padding: 0.55em 0.7em; position: relative;
        transition: color 0.2s var(--hr-ease);
      }
      .hr-nav__idx {
        font-size: 0.6rem; color: var(--hr-ink-faint); margin-right: 0.4em; vertical-align: 0.15em;
        transition: color 0.2s var(--hr-ease);
      }
      .hr-nav__link:hover { color: var(--hr-bone); }
      .hr-nav__link:hover .hr-nav__idx { color: var(--hr-amber); }
      /* Hrotová linka jako aktivní značka */
      .hr-nav__link.is-active { color: var(--hr-bone); }
      .hr-nav__link.is-active .hr-nav__idx { color: var(--hr-amber); }
      .hr-nav__link::after {
        content: ""; position: absolute; left: 0.7em; bottom: 0.45em; height: 1px; width: 0;
        background: var(--hr-amber); transition: width 0.28s var(--hr-ease);
      }
      .hr-nav__link:hover::after { width: calc(100% - 1.4em); }
      .hr-nav__link.is-active::after { width: calc(100% - 1.4em); }
      .hr-nav__link.is-active::before {
        content: ""; position: absolute; right: 0.2em; bottom: 0.42em;
        border-left: 5px solid var(--hr-amber); border-top: 3px solid transparent; border-bottom: 3px solid transparent;
      }
      .hr-nav__cta { margin-left: 0.8rem; padding: 0.75em 1.1em; }

      .hr-burger {
        display: none; margin-left: auto; width: 46px; height: 46px;
        background: transparent; border: 1px solid var(--hr-line-d); border-radius: var(--hr-r);
        cursor: pointer; padding: 0; flex-direction: column; gap: 5px; align-items: center; justify-content: center;
      }
      .hr-burger span { width: 20px; height: 1.5px; background: var(--hr-bone); transition: transform 0.25s var(--hr-ease), opacity 0.2s var(--hr-ease); }
      .hr-burger.is-open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
      .hr-burger.is-open span:nth-child(2) { opacity: 0; }
      .hr-burger.is-open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

      .hr-mobile { border-top: 1px solid var(--hr-line-d); background: var(--hr-ink-2); }
      .hr-mobile__nav { display: flex; flex-direction: column; padding: 0.8rem 4vw 1.4rem; gap: 0.1rem; }
      .hr-mobile__link {
        text-decoration: none; color: var(--hr-bone); font-family: var(--hr-ff-mono); font-weight: 500; font-size: 1rem;
        padding: 0.85em 0.4em; border-bottom: 1px solid var(--hr-line-d); display: flex; align-items: baseline; gap: 0.8em;
      }
      .hr-mobile__idx { font-size: 0.68rem; color: var(--hr-ink-faint); }
      .hr-mobile__link.is-active { color: var(--hr-amber); }
      .hr-mobile__link.is-active .hr-mobile__idx { color: var(--hr-amber); }
      .hr-mobile__cta { margin-top: 1rem; justify-content: center; }

      /* ============ ZÓNY / SEKCE ============ */
      .hr-section { padding: clamp(3.5rem, 8vw, 6.5rem) 0; position: relative; }
      .is-dark { background: var(--hr-ink); color: var(--hr-bone); }
      .is-ink2 { background: var(--hr-ink-2); color: var(--hr-bone); }
      .is-bone { background: var(--hr-bone); color: var(--hr-on-bone); }
      .is-bone-2 { background: var(--hr-bone-2); color: var(--hr-on-bone); }
      .is-steel { background: var(--hr-steel-2); color: var(--hr-on-bone); }
      .is-bone h1, .is-bone h2, .is-bone h3, .is-bone h4,
      .is-bone-2 h1, .is-bone-2 h2, .is-bone-2 h3, .is-bone-2 h4,
      .is-steel h1, .is-steel h2, .is-steel h3, .is-steel h4 { color: var(--hr-on-bone); }
      .is-bone .hr-lede, .is-bone-2 .hr-lede, .is-steel .hr-lede { color: var(--hr-on-bone-soft); }

      /* tečkovaná „flash sheet" textura jako pozadí tmavých zón */
      .hr-grid-tex {
        background-image: radial-gradient(var(--hr-line-d) 1px, transparent 1px);
        background-size: 26px 26px;
      }

      /* společná sekční hlavička */
      .hr-shead { max-width: 64ch; }
      .hr-shead h2 { font-size: clamp(2rem, 4.6vw, 3.4rem); margin-top: 0.9rem; }
      .hr-shead .hr-lede { margin-top: 1.1rem; }
      .hr-shead--end { margin-left: auto; text-align: right; }
      .hr-shead--end .hr-label { flex-direction: row-reverse; }

      /* hlavička podstránky */
      .hr-phead { position: relative; padding: clamp(3.5rem, 8vw, 6rem) 0 clamp(2rem, 4vw, 3rem); overflow: hidden; }
      .hr-phead__inner { position: relative; z-index: 1; }
      .hr-phead h1 { font-size: clamp(2.6rem, 8vw, 5.6rem); }
      .hr-phead__sub { margin-top: 1.3rem; font-size: clamp(1.05rem, 1.7vw, 1.25rem); color: var(--hr-ink-soft); max-width: 60ch; }
      .hr-phead__num {
        position: absolute; right: -1vw; top: 0; font-family: var(--hr-ff-display); font-weight: 800;
        font-size: clamp(8rem, 26vw, 22rem); line-height: 0.7; color: var(--hr-ink-2);
        z-index: 0; pointer-events: none; user-select: none; letter-spacing: -0.04em;
      }

      /* incizní / vlasový předěl */
      .hr-rule { height: 1px; background: var(--hr-line-d); border: 0; margin: 0; }
      .is-bone .hr-rule, .is-bone-2 .hr-rule, .is-steel .hr-rule { background: var(--hr-line-b); }

      /* svislý popisek na desktopu */
      .hr-vlabel {
        writing-mode: vertical-rl; text-orientation: mixed;
        font-family: var(--hr-ff-mono); font-size: 0.7rem; letter-spacing: 0.3em; text-transform: uppercase;
        color: var(--hr-ink-faint);
      }

      /* ============ PATIČKA ============ */
      .hr-foot { background: var(--hr-ink-2); color: var(--hr-bone); border-top: 1px solid var(--hr-line-d); }
      .hr-foot__top {
        display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 2.6rem;
        padding: clamp(3rem, 6vw, 4.5rem) 0 2.6rem;
      }
      .hr-foot__name { font-family: var(--hr-ff-display); font-weight: 800; font-size: 1.5rem; letter-spacing: 0.02em; }
      .hr-foot__tag { color: var(--hr-ink-soft); max-width: 40ch; margin: 0.9rem 0 1.2rem; font-size: 0.95rem; }
      .hr-foot__sig { width: 180px; opacity: 0.9; }
      .hr-foot__k { font-family: var(--hr-ff-mono); font-size: 0.68rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--hr-ink-faint); display: block; margin-bottom: 1rem; }
      .hr-foot__col { display: flex; flex-direction: column; }
      .hr-foot__link { color: var(--hr-ink-soft); text-decoration: none; padding: 0.32em 0; font-size: 0.92rem; display: flex; gap: 0.7em; align-items: baseline; transition: color 0.2s var(--hr-ease); }
      .hr-foot__idx { font-family: var(--hr-ff-mono); font-size: 0.66rem; color: var(--hr-ink-faint); }
      .hr-foot__link:hover { color: var(--hr-amber); }
      .hr-foot__line { color: var(--hr-ink-soft); margin: 0 0 0.45rem; font-size: 0.92rem; }
      .hr-foot__bottom {
        display: flex; flex-wrap: wrap; gap: 0.6rem 1.5rem; justify-content: space-between;
        padding: 1.4rem 0 2.2rem; border-top: 1px solid var(--hr-line-d);
        font-family: var(--hr-ff-mono); font-size: 0.74rem; color: var(--hr-ink-faint);
      }
      .hr-foot__demo, .hr-foot__legal { margin: 0; }
      .hr-foot__moss { color: var(--hr-amber); text-decoration: none; }
      .hr-foot__moss:hover { text-decoration: underline; }

      /* ============ FOCUS ============ */
      .hr-body a:focus-visible, .hr-body button:focus-visible,
      .hr-body input:focus-visible, .hr-body textarea:focus-visible, .hr-body select:focus-visible {
        outline: 2.5px solid var(--hr-amber); outline-offset: 3px; border-radius: 2px;
      }

      /* ============ MOTION ============ */
      .hr-anim { opacity: 0; transform: translateY(20px); transition: opacity 0.7s var(--hr-ease), transform 0.7s var(--hr-ease); }
      .hr-anim.is-in { opacity: 1; transform: none; }
      .hr-anim[data-delay="1"] { transition-delay: 0.07s; }
      .hr-anim[data-delay="2"] { transition-delay: 0.14s; }
      .hr-anim[data-delay="3"] { transition-delay: 0.21s; }
      .hr-anim[data-delay="4"] { transition-delay: 0.28s; }
      .hr-anim[data-delay="5"] { transition-delay: 0.35s; }
      .hr-anim[data-delay="6"] { transition-delay: 0.42s; }

      /* ============ RESPONZIVITA ============ */
      @media (max-width: 1080px) {
        .hr-nav__links, .hr-nav__cta { display: none; }
        .hr-burger { display: flex; }
      }
      @media (max-width: 860px) {
        .hr-foot__top { grid-template-columns: 1fr 1fr; }
        .hr-foot__brand { grid-column: 1 / -1; }
      }
      @media (max-width: 560px) {
        .hr-foot__top { grid-template-columns: 1fr; gap: 2rem; }
        .hr-vlabel { display: none; }
      }

      /* ============ REDUCED MOTION ============ */
      @media (prefers-reduced-motion: reduce) {
        .hr-body * { animation-duration: 0.001ms !important; transition-duration: 0.001ms !important; }
        .hr-anim { opacity: 1 !important; transform: none !important; }
      }
    </style>
  </body>
</html>
