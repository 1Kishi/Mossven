---
import { Image } from "astro:assets";
import Hrot from "./_layout/Hrot.astro";
import Needle from "./_layout/Needle.astro";
import Flash from "./_layout/Flash.astro";

import imgFineLine from "./portfolio-fine-line-01.png";
import imgBlackwork from "./portfolio-blackwork-01.png";
import imgOrnament from "./portfolio-ornament-01.png";
import imgEar from "./portfolio-piercing-ear-01.png";

const base = "/ukazky/tetovani";

const reasons = [
  { k: "Rukopis", t: "Autorský návrh, ne katalog", p: "Motiv vzniká podle stylu, umístění a velikosti. Řešíme kompozici, čitelnost i to, jak práce zestárne na kůži." },
  { k: "Sterilita", t: "Hygiena jako základ, ne doplněk", p: "Sterilní nástroje, jednorázový materiál, dezinfikované plochy. Každý krok má svůj postup a kontrolu." },
  { k: "Klid", t: "Konzultace před každým zákrokem", p: "Než se sáhne po jehle, projdeme motiv, cenu, čas i kontraindikace. Bez tlaku a bez spěchu." },
  { k: "Péče", t: "Hojení neřešíte sami", p: "Z ateliéru odcházíte s písemnými instrukcemi a možností se kdykoliv ozvat, když si nejste jistí." },
];

const portfolio = [
  { img: imgFineLine, alt: "Jemné linkové tetování na předloktí", cat: "Jemná linka", meta: "předloktí", tag: "čerstvé" },
  { img: imgBlackwork, alt: "Blackwork tetování na paži", cat: "Blackwork", meta: "paže", tag: "zahojeno", big: true },
  { img: imgEar, alt: "Piercing ucha s titanovým šperkem", cat: "Piercing", meta: "ucho · titan", tag: "" },
  { img: imgOrnament, alt: "Ornamentální tetování na předloktí", cat: "Ornament", meta: "předloktí", tag: "" },
];

const services = [
  { cat: "Tetování", t: "Autorské tetování", p: "Návrh na míru podle stylu a umístění." },
  { cat: "Tetování", t: "Fine-line", p: "Jemné linky a decentní menší motivy." },
  { cat: "Tetování", t: "Blackwork & ornament", p: "Kontrastní plochy stavěné na siluetě těla." },
  { cat: "Piercing", t: "Piercing", p: "Sterilní aplikace, vhodný šperk, jasné hojení." },
  { cat: "Příprava", t: "Konzultace", p: "Motiv, cena, čas, kontraindikace, péče." },
  { cat: "Úprava", t: "Úprava / překrytí", p: "Možnosti po osobní konzultaci." },
];

const steps = [
  { n: "01", t: "Ozvete se", p: "Napíšete, co chcete řešit. Přidáte umístění, velikost a pár referencí stylu." },
  { n: "02", t: "Konzultace", p: "Sejdeme se nad motivem. Probereme kompozici, cenu, čas i kontraindikace." },
  { n: "03", t: "Příprava", p: "Sterilní pracoviště, jednorázový materiál, transfer návrhu a kontrola umístění." },
  { n: "04", t: "Zákrok", p: "Pracujeme v klidu a s přestávkami. Víte, co se děje a jak dlouho to potrvá." },
  { n: "05", t: "Péče po zákroku", p: "Odejdete s písemnými instrukcemi. Na dotazy během hojení odpovídáme." },
];

const pricePeek = [
  { t: "Malý motiv", v: "od 1 500 Kč" },
  { t: "Jemné linky", v: "od 1 800 Kč" },
  { t: "Střední motiv", v: "od 3 500 Kč" },
  { t: "Piercing ucho", v: "od 700 Kč" },
  { t: "Piercing nos", v: "od 900 Kč" },
  { t: "Konzultace", v: "zdarma" },
];
---

<Hrot
  title="Ateliér Hrot — autorské tetování a piercing v Brně"
  description="Autorské tetování, piercing a konzultace v ateliéru, kde má styl stejnou váhu jako hygiena, komunikace a péče po zákroku. Ostré linky, čistá práce, bezpečný průběh. Ukázkový web od Mossven."
  active="uvod"
>
  <!-- ============ HERO ============ -->
  <section class="hr-hero hr-grid-tex" aria-labelledby="hr-hero-h">
    <span class="hr-vlabel hr-hero__vlabel" aria-hidden="true">Ateliér Hrot · est. fiktivně</span>
    <div class="hr-wrap hr-hero__grid">
      <div class="hr-hero__text">
        <p class="hr-label hr-anim is-in">Tetování · Piercing · Brno</p>
        <h1 id="hr-hero-h" class="hr-hero__title hr-anim is-in" data-delay="1">
          Tetování a&nbsp;piercing s&nbsp;<span class="hr-hero__em">přesností</span>, klidem a&nbsp;čistou hlavou.
        </h1>
        <p class="hr-lede hr-hero__sub hr-anim is-in" data-delay="2">
          Autorské tetování, piercing a konzultace v ateliéru, kde má styl stejnou váhu
          jako hygiena, komunikace a péče po zákroku.
        </p>
        <div class="hr-hero__cta hr-anim is-in" data-delay="3">
          <a class="hr-btn hr-btn--solid" href={`${base}/kontakt`}>Domluvit konzultaci <span class="hr-btn__arrow">→</span></a>
          <a class="hr-btn hr-btn--ghost" href={`${base}/portfolio`}>Prohlédnout portfolio</a>
        </div>
        <ul class="hr-trust hr-anim is-in" data-delay="4">
          <li>Sterilní nástroje</li>
          <li>Jasný ceník</li>
          <li>Konzultace předem</li>
          <li>Péče po zákroku</li>
          <li>Lokální ateliér</li>
        </ul>
      </div>

      <figure class="hr-hero__feature hr-anim is-in" data-delay="2">
        <span class="hr-hero__stamp hr-mono" aria-hidden="true"><b>HROT-04</b>BLACKWORK<br />· HEALED ·</span>
        <div class="hr-hero__featimg">
          <Image src={imgBlackwork} alt="Detail blackwork tetování na paži — ostré kontrastní plochy a čistá silueta" widths={[520, 820, 1200]} sizes="(max-width: 980px) 92vw, 46vw" format="webp" quality={80} loading="eager" decoding="async" />
        </div>
        <span class="hr-hero__rule" aria-hidden="true"></span>
        <figcaption class="hr-hero__featcap hr-mono"><span>FLASH 04 — paže</span><span>085 × 220 mm</span></figcaption>
      </figure>
    </div>

    <div class="hr-wrap hr-hero__needle"><Needle variant="divider" /></div>
  </section>

  <!-- ============ PROČ HROT ============ -->
  <section class="hr-section is-ink2 hr-why" aria-labelledby="hr-why-h">
    <div class="hr-wrap">
      <div class="hr-shead hr-anim">
        <p class="hr-label">Proč Hrot</p>
        <h2 id="hr-why-h">Ateliér, ne salon. Značka na kůži, ne služba na běžícím pásu.</h2>
      </div>
      <div class="hr-why__grid">
        {reasons.map((r, i) => (
          <article class="hr-why__item hr-anim" data-delay={String((i % 4) + 1)}>
            <span class="hr-why__k hr-mono">{r.k}</span>
            <h3 class="hr-why__t">{r.t}</h3>
            <p class="hr-why__p">{r.p}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ PORTFOLIO PREVIEW ============ -->
  <section class="hr-section is-bone hr-pf" aria-labelledby="hr-pf-h">
    <div class="hr-wrap">
      <div class="hr-pf__head">
        <div class="hr-shead hr-anim">
          <p class="hr-label">Vybrané práce</p>
          <h2 id="hr-pf-h">Flash sheet a&nbsp;galerijní stěna v&nbsp;jednom.</h2>
        </div>
        <a class="hr-btn hr-btn--ghost hr-anim" href={`${base}/portfolio`}>Celé portfolio <span class="hr-btn__arrow">→</span></a>
      </div>
      <div class="hr-pf__wall">
        {portfolio.map((p, i) => (
          <article class:list={["hr-pcard hr-anim", { "hr-pcard--big": p.big }]} data-delay={String((i % 4) + 1)}>
            <div class="hr-pcard__art"><Image src={p.img} alt={p.alt} widths={[400, 700]} sizes="(max-width: 980px) 50vw, 25vw" format="webp" quality={74} loading="lazy" decoding="async" /></div>
            <div class="hr-pcard__meta">
              <span class="hr-pcard__cat hr-mono">{p.cat}</span>
              <span class="hr-pcard__loc">{p.meta}</span>
              {p.tag && <span class:list={["hr-pcard__tag hr-mono", p.tag === "zahojeno" ? "is-healed" : "is-fresh"]}>{p.tag}</span>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ SLUŽBY OVERVIEW ============ -->
  <section class="hr-section is-dark hr-grid-tex hr-sv" aria-labelledby="hr-sv-h">
    <div class="hr-wrap">
      <div class="hr-shead hr-anim">
        <p class="hr-label">Co děláme</p>
        <h2 id="hr-sv-h">Od jemné linky po ornament. A&nbsp;piercing se sterilním postupem.</h2>
      </div>
      <ul class="hr-sv__list">
        {services.map((s, i) => (
          <li class="hr-sv__row hr-anim" data-delay={String((i % 6) + 1)}>
            <span class="hr-sv__cat hr-mono">{s.cat}</span>
            <span class="hr-sv__t">{s.t}</span>
            <span class="hr-sv__p">{s.p}</span>
            <a class="hr-sv__go" href={`${base}/sluzby`} aria-label={`Více o: ${s.t}`}>→</a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============ HYGIENA PROMISE ============ -->
  <section class="hr-section is-steel hr-hg" aria-labelledby="hr-hg-h">
    <div class="hr-wrap hr-hg__grid">
      <div class="hr-hg__text hr-anim">
        <p class="hr-label">Hygiena</p>
        <h2 id="hr-hg-h">Hygiena není doplněk. Je to základ každé práce.</h2>
        <p class="hr-lede">Každý zákrok probíhá s čistým pracovním místem, sterilními nástroji, jednorázovým materiálem a jasnými instrukcemi pro péči po zákroku.</p>
        <a class="hr-btn hr-btn--ghost" href={`${base}/hygiena`}>Jak to u nás funguje <span class="hr-btn__arrow">→</span></a>
      </div>
      <ul class="hr-hg__check hr-anim" data-delay="1">
        <li>Sterilní jehly a jednorázový materiál</li>
        <li>Dezinfikované pracovní plochy</li>
        <li>Rukavice po celou dobu zákroku</li>
        <li>Bezpečné zacházení s nástroji</li>
        <li>Šperky vhodné pro první aplikaci</li>
        <li>Písemné instrukce k péči</li>
      </ul>
    </div>
  </section>

  <!-- ============ PROCES ============ -->
  <section class="hr-section is-dark hr-proc" aria-labelledby="hr-proc-h">
    <div class="hr-wrap">
      <div class="hr-shead hr-anim">
        <p class="hr-label">Průběh</p>
        <h2 id="hr-proc-h">Od zprávy po zhojenou práci v&nbsp;pěti krocích.</h2>
      </div>
      <ol class="hr-proc__list">
        {steps.map((st, i) => (
          <li class="hr-proc__step hr-anim" data-delay={String((i % 5) + 1)}>
            <div class="hr-proc__seam" aria-hidden="true"><Needle variant="seam" /></div>
            <span class="hr-proc__n hr-display">{st.n}</span>
            <h3 class="hr-proc__t">{st.t}</h3>
            <p class="hr-proc__p">{st.p}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============ CENÍK PREVIEW ============ -->
  <section class="hr-section is-bone-2 hr-price" aria-labelledby="hr-price-h">
    <div class="hr-wrap hr-price__grid">
      <div class="hr-price__head hr-anim">
        <p class="hr-label">Ceník · ukázka</p>
        <h2 id="hr-price-h">Orientační ceny předem, finální po&nbsp;konzultaci.</h2>
        <p class="hr-lede">Přesná cena závisí na velikosti, umístění, detailu a délce práce. U tetování se potvrzuje po konzultaci.</p>
        <a class="hr-btn hr-btn--ghost" href={`${base}/cenik`}>Celý ceník <span class="hr-btn__arrow">→</span></a>
      </div>
      <dl class="hr-price__sheet hr-anim" data-delay="1">
        {pricePeek.map((p) => (
          <div class="hr-price__row">
            <dt>{p.t}</dt>
            <dd class="hr-mono">{p.v}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- ============ ZÁVĚREČNÁ CTA ============ -->
  <section class="hr-section is-dark hr-grid-tex hr-end" aria-labelledby="hr-end-h">
    <div class="hr-wrap hr-end__inner hr-anim">
      <div class="hr-end__mark" aria-hidden="true"><Flash motif="arrow" tone="amber" /></div>
      <p class="hr-label hr-label--bare">Rezervace</p>
      <h2 id="hr-end-h" class="hr-end__h">Máte motiv v hlavě? Pojďme ho dotáhnout.</h2>
      <p class="hr-end__p">Napište, co řešíte — tetování, piercing, nebo jen nezávaznou konzultaci. U tetování pomůže přidat velikost, místo na těle a pár referencí stylu.</p>
      <div class="hr-end__cta">
        <a class="hr-btn hr-btn--solid" href={`${base}/kontakt`}>Domluvit konzultaci <span class="hr-btn__arrow">→</span></a>
        <a class="hr-btn hr-btn--ghost" href={`${base}/hygiena`}>Pravidla hygieny</a>
      </div>
    </div>
  </section>

  <style>
    /* ===== HERO ===== */
    .hr-hero { position: relative; padding: clamp(2.5rem, 6vw, 5rem) 0 0; }
    .hr-hero__vlabel { position: absolute; left: max(12px, calc((100vw - var(--hr-maxw)) / 2 - 28px)); top: clamp(3rem, 7vw, 6rem); }
    .hr-hero__grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: clamp(2rem, 5vw, 4.5rem); align-items: center; padding-bottom: clamp(2rem, 5vw, 4rem); }
    .hr-hero__title { font-size: clamp(3rem, 8.6vw, 7.2rem); letter-spacing: -0.035em; line-height: 0.92; font-weight: 800; }
    .hr-hero__em { color: var(--hr-amber); font-style: italic; }
    .hr-hero__sub { margin: 1.8rem 0 2rem; }
    .hr-hero__cta { display: flex; gap: 0.8rem; flex-wrap: wrap; }
    .hr-trust { list-style: none; padding: 0; margin: 2.4rem 0 0; display: flex; flex-wrap: wrap; gap: 0.5rem 1.4rem; }
    .hr-trust li { font-family: var(--hr-ff-mono); font-size: 0.76rem; color: var(--hr-ink-soft); display: flex; align-items: center; gap: 0.55em; }
    .hr-trust li::before { content: ""; width: 6px; height: 6px; background: var(--hr-amber); transform: rotate(45deg); flex: none; }

    /* hero feature — brutálně oříznutý blackwork */
    .hr-hero__feature { position: relative; margin: 0; aspect-ratio: 4 / 5; width: 100%; max-width: 480px; margin-inline: auto; }
    .hr-hero__featimg { position: relative; height: 100%; border-radius: var(--hr-r); overflow: hidden; border: 1px solid var(--hr-line-d); background: var(--hr-ink-2); }
    .hr-hero__featimg :global(img) { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; filter: saturate(0.9) contrast(1.1) brightness(0.95); }
    .hr-hero__feature::after { content: ""; position: absolute; inset: 0; pointer-events: none; border-radius: var(--hr-r); box-shadow: inset 0 -80px 90px -50px rgba(0,0,0,0.75); }
    .hr-hero__stamp { position: absolute; z-index: 4; top: 1.1rem; right: -0.7rem; text-align: right; font-size: 0.6rem; letter-spacing: 0.22em; line-height: 1.55; color: var(--hr-ink); background: var(--hr-amber); padding: 0.5rem 0.7rem; border-radius: 2px; box-shadow: 0 14px 32px -14px rgba(0,0,0,0.85); }
    .hr-hero__stamp b { display: block; font-size: 0.95rem; letter-spacing: 0.1em; }
    .hr-hero__rule { position: absolute; z-index: 4; left: -0.7rem; top: 14%; bottom: 14%; width: 0; border-left: 1px solid var(--hr-amber); }
    .hr-hero__rule::before, .hr-hero__rule::after { content: ""; position: absolute; left: -4px; width: 9px; height: 1px; background: var(--hr-amber); }
    .hr-hero__rule::before { top: 0; } .hr-hero__rule::after { bottom: 0; }
    .hr-hero__featcap { position: absolute; z-index: 4; left: 0; right: 0; bottom: 0.8rem; padding: 0 1rem; display: flex; justify-content: space-between; gap: 1rem; font-size: 0.62rem; letter-spacing: 0.1em; color: var(--hr-bone); text-transform: uppercase; }
    .hr-hero__needle { padding-bottom: 2.5rem; color: var(--hr-amber); }

    /* ===== PROČ HROT ===== */
    .hr-why__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; margin-top: 3rem; background: var(--hr-line-d); border: 1px solid var(--hr-line-d); }
    .hr-why__item { background: var(--hr-ink-2); padding: 1.8rem 1.5rem 2rem; display: flex; flex-direction: column; }
    .hr-why__k { font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--hr-amber); }
    .hr-why__t { font-size: 1.32rem; margin: 1.4rem 0 0.7rem; line-height: 1.05; }
    .hr-why__p { color: var(--hr-ink-soft); margin: 0; font-size: 0.95rem; }

    /* ===== PORTFOLIO ===== */
    .hr-pf__head { display: flex; align-items: flex-end; justify-content: space-between; gap: 2rem; margin-bottom: 2.6rem; flex-wrap: wrap; }
    .hr-pf__wall { display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: 1fr; gap: 1rem; }
    .hr-pcard { background: var(--hr-bone-2); border: 1px solid var(--hr-line-b); border-radius: var(--hr-r); overflow: hidden; transition: transform 0.25s var(--hr-ease), box-shadow 0.25s var(--hr-ease); display: flex; flex-direction: column; }
    .hr-pcard:hover { transform: translateY(-4px); box-shadow: 0 24px 48px -28px rgba(42,37,32,0.55); }
    .hr-pcard--big { grid-row: span 2; }
    .hr-pcard__art { flex: 1; overflow: hidden; border-bottom: 1px solid var(--hr-line-b); min-height: 240px; }
    .hr-pcard__art :global(img) { width: 100%; height: 100%; object-fit: cover; display: block; filter: saturate(0.92) contrast(1.04); transition: transform 0.5s var(--hr-ease); }
    .hr-pcard:hover .hr-pcard__art :global(img) { transform: scale(1.05); }
    .hr-pcard__meta { padding: 0.9rem 1rem 1rem; display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5em 0.7em; }
    .hr-pcard__cat { font-size: 0.7rem; letter-spacing: 0.1em; color: var(--hr-on-bone); text-transform: uppercase; }
    .hr-pcard__loc { font-size: 0.82rem; color: var(--hr-on-bone-soft); }
    .hr-pcard__tag { font-size: 0.62rem; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.25em 0.6em; border-radius: 2px; margin-left: auto; }
    .hr-pcard__tag.is-healed { background: var(--hr-purple); color: var(--hr-bone); }
    .hr-pcard__tag.is-fresh { background: var(--hr-amber); color: var(--hr-ink); }

    /* ===== SLUŽBY ===== */
    .hr-sv__list { list-style: none; padding: 0; margin: 3rem 0 0; border-top: 1px solid var(--hr-line-d); }
    .hr-sv__row { display: grid; grid-template-columns: 130px 1.1fr 2fr 40px; align-items: center; gap: 1.5rem; padding: 1.4rem 0.4rem; border-bottom: 1px solid var(--hr-line-d); transition: padding 0.2s var(--hr-ease); }
    .hr-sv__row:hover { padding-left: 1rem; background: linear-gradient(90deg, color-mix(in srgb, var(--hr-amber) 7%, transparent), transparent 40%); }
    .hr-sv__cat { font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--hr-amber); }
    .hr-sv__t { font-family: var(--hr-ff-display); font-weight: 700; font-size: 1.3rem; letter-spacing: -0.01em; }
    .hr-sv__p { color: var(--hr-ink-soft); font-size: 0.95rem; }
    .hr-sv__go { text-decoration: none; color: var(--hr-bone); font-size: 1.3rem; justify-self: end; opacity: 0.5; transition: opacity 0.2s var(--hr-ease), transform 0.2s var(--hr-ease); }
    .hr-sv__row:hover .hr-sv__go { opacity: 1; transform: translateX(4px); color: var(--hr-amber); }

    /* ===== HYGIENA PROMISE ===== */
    .hr-hg__grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: clamp(2rem, 5vw, 4rem); align-items: center; }
    .hr-hg__text h2 { font-size: clamp(1.9rem, 4vw, 3rem); margin: 0.9rem 0 1.1rem; }
    .hr-hg__text .hr-btn { margin-top: 1.6rem; }
    .hr-hg__check { list-style: none; margin: 0; padding: 0; display: grid; gap: 0; border: 1px solid var(--hr-line-b); border-radius: var(--hr-r); background: color-mix(in srgb, #fff 30%, var(--hr-steel-2)); }
    .hr-hg__check li { display: flex; align-items: center; gap: 0.9em; padding: 0.95rem 1.2rem; border-bottom: 1px solid var(--hr-line-b); font-size: 0.96rem; color: var(--hr-on-bone); }
    .hr-hg__check li:last-child { border-bottom: 0; }
    .hr-hg__check li::before { content: "✕"; font-family: var(--hr-ff-mono); font-size: 0.7rem; color: var(--hr-ink); background: var(--hr-amber); width: 20px; height: 20px; display: grid; place-items: center; border-radius: 2px; flex: none; }

    /* ===== PROCES ===== */
    .hr-proc__list { list-style: none; padding: 0; margin: 3rem 0 0; display: grid; grid-template-columns: repeat(5, 1fr); gap: 0; }
    .hr-proc__step { position: relative; padding: 0 1.2rem 0 0; }
    .hr-proc__seam { position: absolute; top: 0.2rem; right: 0; height: 70px; width: 22px; color: var(--hr-line-d); }
    .hr-proc__step:last-child .hr-proc__seam { display: none; }
    .hr-proc__n { display: block; font-size: 2.4rem; color: var(--hr-amber); margin-bottom: 0.8rem; }
    .hr-proc__t { font-size: 1.2rem; margin-bottom: 0.5rem; }
    .hr-proc__p { color: var(--hr-ink-soft); font-size: 0.92rem; margin: 0; padding-right: 0.8rem; }

    /* ===== CENÍK PREVIEW ===== */
