---
// Ukázkový (demo) web pro fiktivního osobního trenéra „Forma".
// Samostatná stránka - vlastní identita, nepoužívá Mossven Layout.
// Redesign v3: klidná, strukturovaná, technická a přívětivá značka osobního
// trenéra. Hlavní metafora: postup 0 → 100, rytmus, technika, pravidelnost.
// Hero = split s vlastní „tréninkovou nástěnkou"; průběžná lišta postupu;
// programové karty; týdenní kalendář; měřicí mřížka + textura. Route: /ukazky/trener
import { Image } from "astro:assets";

import fotoHero from "./trener-one/trener-hero-koucink.png";
import fotoTechnika from "./trener-one/trener-technika-cviku.png";
import fotoSila from "./trener-one/trener-silovy-trenink.png";
import fotoPlan from "./trener-one/trener-plan-tydne.png";
import fotoZacatecnik from "./trener-one/trener-zacatecnik.png";
import fotoPortret from "./trener-one/trener-portret.png";

const trener = { jmeno: "Tomáš" };

const programy = [
  { kod: "01", img: fotoSila, imgAlt: "Klientka cvičí vsedě s jednoručkami, trenér ji vede a hlídá provedení", nazev: "1:1 osobní trénink", proKoho: "Pro začátečníky i pokročilé", delka: "60 min", format: "ve studiu", cena: "od 700 Kč", popis: "Trénink jen pro vás. Plán, technika a tempo podle toho, kde teď jste — bez čekání na nikoho." },
  { kod: "02", img: fotoTechnika, imgAlt: "Trenér opravuje techniku cviku a hlídá správné držení těla", nazev: "Trénink ve dvojici", proKoho: "Pro parťáky a páry", delka: "60 min", format: "ve studiu", cena: "od 500 Kč/os.", popis: "S parťákem nebo partnerkou. Levnější, o dost zábavnější a o motivaci je postaráno." },
  { kod: "03", img: fotoPlan, imgAlt: "Otevřený zápisník s rozpisem tréninku, lahev s vodou a činka na lavici", nazev: "Plán na doma", proKoho: "Pro samostatné", delka: "4 týdny", format: "online", cena: "od 1 490 Kč", popis: "Rozpis na míru a opora přes zprávy. Když nestíháte do studia, ale chcete vědět, co a jak." },
];

const milniky = [
  { k: "1.", t: "trénink", d: "Projdeme cíl, zdraví a techniku. Nezávazně a v klidu." },
  { k: "4", t: "týdny", d: "Technika sedí a plán běží skoro sám." },
  { k: "12", t: "týdnů", d: "Cítíte sílu, kondici i větší jistotu v pohybu." },
  { k: "∞", t: "návyk", d: "Trénink, který vydrží, i když zrovna nejsme spolu." },
];

const mereni = [
  { label: "Technika", val: "8 / 10", unit: "cviků čistě", p: 80, cap: "Provedení hlídáme každý trénink, ne jen na začátku." },
  { label: "Síla", val: "+18 %", unit: "za 12 týdnů", p: 68, cap: "Zátěž přidáváme postupně, podle toho, jak vám to jde." },
  { label: "Návyk", val: "9 týdnů", unit: "v řadě", p: 75, cap: "Dva tréninky týdně. Bez výčitek, bez dřiny na krev." },
];

// Týdenní kalendář: kind řídí „váhu" buňky, dots = intenzita (0–3).
const tyden = [
  { d: "Po", t: "Síla", kind: "silne", dots: 3, note: "dřep + tah" },
  { d: "Út", t: "Mobilita", kind: "mekke", dots: 1, note: "kyčle, páteř" },
  { d: "St", t: "Volno", kind: "volno", dots: 0, note: "regenerace" },
  { d: "Čt", t: "Síla", kind: "silne", dots: 3, note: "tlak + dřep" },
  { d: "Pá", t: "Kondice", kind: "stred", dots: 2, note: "intervaly" },
  { d: "So", t: "Lehce", kind: "lehke", dots: 1, note: "procházka" },
  { d: "Ne", t: "Volno", kind: "volno", dots: 0, note: "odpočinek" },
];

const prokoho = [
  "Začínáte a nechcete si ublížit špatnou technikou",
  "Vracíte se po pauze nebo po zranění a chcete jistotu",
  "Trénujete sami, ale přestalo to fungovat",
  "Chcete plán, který sedne do běžného týdne",
];
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forma — osobní trénink bez drama</title>
    <meta name="description" content="Osobní trénink na míru s Tomášem: síla, kondice a technika podle toho, kde teď jste. Sledujeme reálný pokrok 0 → 100. První trénink na zkoušku. Ukázkový web od Mossven." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@500;600;700;800;900&family=Sora:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="fo-body">
    <!-- Průběžná lišta postupu 0 → 100 (signature, váže se na scroll) -->
    <div class="fo-rail" aria-hidden="true">
      <span class="fo-rail__cap">postup</span>
      <div class="fo-rail__track">
        <span class="fo-rail__tick" style="top:0%"></span>
        <span class="fo-rail__tick" style="top:25%"></span>
        <span class="fo-rail__tick" style="top:50%"></span>
        <span class="fo-rail__tick" style="top:75%"></span>
        <span class="fo-rail__tick" style="top:100%"></span>
        <span class="fo-rail__fill"></span>
      </div>
      <span class="fo-rail__num"><b id="fo-railnum">0</b>/100</span>
    </div>

    <header class="fo-top">
      <div class="fo-wrap fo-top__inner">
        <a class="fo-brand" href="#fo-top" aria-label="Forma, domů">
          <span class="fo-brand__name">FORMA</span>
          <span class="fo-brand__sub">trénink s&nbsp;{trener.jmeno}</span>
        </a>
        <nav class="fo-top__nav" aria-label="Hlavní">
          <a href="#fo-programy">Programy</a>
          <a href="#fo-postup">Postup</a>
          <a href="#fo-tyden">Týden</a>
          <a href="#fo-kohto">Pro koho</a>
        </nav>
        <a class="fo-btn fo-btn--pill fo-top__cta" href="#fo-kontakt">Začít<span class="fo-btn__arr" aria-hidden="true">→</span></a>
      </div>
    </header>

    <main id="fo-top">
      <!-- ████ HERO — split: titulek + tréninková nástěnka ████ -->
      <section class="fo-hero" aria-labelledby="fo-hero-title">
        <div class="fo-wrap fo-hero__grid">
          <div class="fo-hero__text">
            <p class="fo-eyebrow"><span class="fo-eyebrow__dot" aria-hidden="true"></span>Osobní trénink · České Budějovice</p>
            <h1 id="fo-hero-title" class="fo-hero__title">
              <span>DOSTAŇTE</span>
              <span>SE DO <span class="fo-hero__formy">FORMY.</span></span>
              <span class="fo-hero__title-em">BEZ DRAMA.</span>
            </h1>
            <p class="fo-hero__sub">
              Trénink na míru podle toho, kde teď jste, ne podle obrázku na internetu.
              Naučím vás techniku, postavím plán a pohlídám, ať to dává smysl a vydrží.
            </p>
            <div class="fo-hero__cta">
              <a class="fo-btn fo-btn--solid" href="#fo-kontakt">Domluvit první trénink</a>
              <a class="fo-btn fo-btn--line" href="#fo-programy">Zobrazit programy</a>
            </div>
            <p class="fo-hero__sign">— vede {trener.jmeno}, osobní trenér &nbsp;·&nbsp; 8 let praxe &nbsp;·&nbsp; 1. trénink na zkoušku</p>
          </div>

          <!-- Tréninková nástěnka (custom dashboard) -->
          <aside class="fo-dash" aria-label="Ukázka tréninkového plánu klienta">
            <figure class="fo-dash__photo">
              <Image src={fotoHero} alt="Trenér klidně vede klientku u dřepu s kettlebellem ve světlém studiu" widths={[420, 640, 860]} sizes="(max-width: 980px) 80vw, 360px" format="webp" quality={80} loading="eager" decoding="async" />
              <span class="fo-dash__live" aria-hidden="true"></span>
              <span class="fo-dash__name">Vede {trener.jmeno}</span>
            </figure>

            <div class="fo-dash__body">
              <div class="fo-dash__head">
                <span class="fo-dash__klabel">Váš postup</span>
                <span class="fo-dash__wk">Týden 6 / 12</span>
              </div>

              <!-- 0 → 100 -->
              <div class="fo-prog2">
                <div class="fo-prog2__bar"><span class="fo-prog2__fill" style="--p:62%"><span class="fo-prog2__knob"></span></span></div>
                <div class="fo-prog2__scale"><span>0</span><span>25</span><span>50</span><span>75</span><span>100</span></div>
                <div class="fo-prog2__val"><b id="fo-count" data-to="62">0</b><span>/ 100</span></div>
              </div>

              <!-- příští trénink -->
              <div class="fo-dash__next">
                <span class="fo-dash__rlabel">Příští trénink</span>
                <div class="fo-dash__nrow">
                  <span class="fo-dash__nday">Čt&nbsp;17:00</span>
                  <span class="fo-pill fo-pill--lime">Síla</span>
                  <span class="fo-pill fo-pill--time"><span class="fo-pill__dot" aria-hidden="true"></span>60:00</span>
                </div>
              </div>

              <!-- mini rytmus -->
              <div class="fo-dash__mini">
                <span class="fo-dash__rlabel">Týdenní rytmus</span>
                <ul class="fo-mini">
                  {tyden.map((w) => (
                    <li class={`fo-mini__d fo-mini__d--${w.kind}`}><span class="fo-mini__bar" style={`--h:${[6,34,58,82][w.dots]}%`}></span><span class="fo-mini__lab">{w.d}</span></li>
                  ))}
                </ul>
              </div>

              <!-- poznámky kouče -->
              <ul class="fo-dash__notes">
                <li><span class="fo-note__ic" aria-hidden="true">✓</span>technika dřepu sedí</li>
                <li><span class="fo-note__ic fo-note__ic--up" aria-hidden="true">↑</span>+2,5&nbsp;kg na sérii</li>
                <li><span class="fo-note__ic" aria-hidden="true">◷</span>3×8 v klidném tempu</li>
              </ul>
            </div>
          </aside>
        </div>
      </section>

      <!-- ████ MILNÍKY — stepped line / measurable ████ -->
      <section class="fo-mile-sec" data-reveal>
        <div class="fo-wrap">
          <p class="fo-sect-tag"><span class="fo-sect-tag__tick" aria-hidden="true"></span>Cesta 0 → 100 · krok za krokem, ne přes noc</p>
          <ol class="fo-mile">
            <span class="fo-mile__line" aria-hidden="true"></span>
            {milniky.map((m) => (
              <li class="fo-mile__item">
                <span class="fo-mile__dot" aria-hidden="true"></span>
                <span class="fo-mile__k">{m.k}</span>
                <span class="fo-mile__t">{m.t}</span>
                <span class="fo-mile__d">{m.d}</span>
              </li>
            ))}
          </ol>
        </div>
      </section>

      <!-- ████ PROGRAMY — karty ████ -->
      <section id="fo-programy" class="fo-section fo-programs">
        <div class="fo-wrap">
          <header class="fo-head fo-head--split">
            <div>
              <p class="fo-sect-tag"><span class="fo-sect-tag__tick" aria-hidden="true"></span>Programy / 01</p>
              <h2 class="fo-head__title">Vyberte si formát,<br />který vám sedne</h2>
            </div>
            <p class="fo-head__aside">Tři způsoby, jak začít. Vždycky s plánem na míru a kontrolou techniky — liší se jen tím, jak a s kým trénujete.</p>
          </header>
          <ul class="fo-cards">
            {programy.map((p) => (
              <li class="fo-card" data-reveal>
                <figure class="fo-card__media">
                  <Image src={p.img} alt={p.imgAlt} widths={[420, 640, 860]} sizes="(max-width: 980px) 92vw, 360px" format="webp" quality={76} loading="lazy" decoding="async" />
                  <span class="fo-card__kod" aria-hidden="true">{p.kod}</span>
                </figure>
                <div class="fo-card__body">
                  <span class="fo-card__tag">{p.proKoho}</span>
                  <h3 class="fo-card__nazev">{p.nazev}</h3>
                  <p class="fo-card__popis">{p.popis}</p>
                  <div class="fo-chips">
                    <span class="fo-chip"><span class="fo-chip__k">Délka</span><span class="fo-chip__v">{p.delka}</span></span>
                    <span class="fo-chip"><span class="fo-chip__k">Formát</span><span class="fo-chip__v">{p.format}</span></span>
                    <span class="fo-chip fo-chip--price"><span class="fo-chip__k">Cena</span><span class="fo-chip__v">{p.cena}</span></span>
                  </div>
                </div>
              </li>
            ))}
          </ul>
          <p class="fo-programs__note">Ceny jsou orientační. U permanentek vyjde trénink levněji — konkrétní cenu domluvíme podle počtu vstupů.</p>
        </div>
      </section>

      <!-- ████ CO SPOLU SLEDUJEME — karty postupu ████ -->
      <section id="fo-postup" class="fo-section fo-track-sec" data-reveal>
        <div class="fo-wrap">
          <header class="fo-head fo-head--split">
            <div>
              <p class="fo-sect-tag"><span class="fo-sect-tag__tick" aria-hidden="true"></span>Postup / 02</p>
              <h2 class="fo-head__title">Co spolu<br />sledujeme</h2>
            </div>
            <p class="fo-head__aside">Neměříme váhu na štítku. Měříme, co se opravdu mění: jak zvedáte, jak se hýbete a jestli u toho zůstanete. Po každém bloku si to spolu projdeme.</p>
          </header>
          <ul class="fo-pcards">
            {mereni.map((m) => (
              <li class="fo-pcard fo-pcard--lg">
                <span class="fo-pcard__label">{m.label}</span>
                <span class="fo-pcard__val">{m.val} <small>{m.unit}</small></span>
                <div class="fo-track"><span class="fo-track__fill" style={`--p:${m.p}%`}></span></div>
                <span class="fo-pcard__cap">{m.cap}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- ████ TÝDENNÍ RYTMUS — kalendář ████ -->
      <section id="fo-tyden" class="fo-section fo-week" data-reveal>
        <div class="fo-wrap">
          <header class="fo-head fo-head--split fo-head--light">
            <div>
              <p class="fo-sect-tag fo-sect-tag--light"><span class="fo-sect-tag__tick" aria-hidden="true"></span>Týden / 03</p>
              <h2 class="fo-head__title fo-head__title--light">Rytmus,<br />ne dřina každý den</h2>
            </div>
            <p class="fo-head__aside fo-head__aside--light">Tělo roste mezi tréninky. Týden stavíme tak, aby měl tvrdší i lehčí dny a den úplného volna — udržitelně, ne na krev.</p>
          </header>
          <ol class="fo-cal" role="img" aria-label="Ukázkový týden: pondělí síla, úterý mobilita, středa volno, čtvrtek síla, pátek kondice, sobota lehce, neděle volno">
            {tyden.map((w) => (
              <li class={`fo-cell fo-cell--${w.kind}`}>
                <span class="fo-cell__d">{w.d}</span>
                <span class="fo-cell__dots" aria-hidden="true">
                  <i class={w.dots > 0 ? "on" : ""}></i><i class={w.dots > 1 ? "on" : ""}></i><i class={w.dots > 2 ? "on" : ""}></i>
                </span>
                <span class="fo-cell__t">{w.t}</span>
                <span class="fo-cell__note">{w.note}</span>
              </li>
            ))}
          </ol>
          <p class="fo-week__note">Ukázkový rozvrh. Skutečný plán sestavíme podle vašich možností a cíle — klidně jen 2× týdně.</p>
        </div>
      </section>

      <!-- ████ PRO KOHO ████ -->
      <section id="fo-kohto" class="fo-section fo-who">
        <div class="fo-wrap fo-who__inner">
          <div class="fo-who__col" data-reveal>
            <p class="fo-sect-tag"><span class="fo-sect-tag__tick" aria-hidden="true"></span>Pro koho / 04</p>
            <h2 class="fo-who__h">Nemusíte být fit,<br />abyste <em>začali</em></h2>
            <p class="fo-who__lead">Většina lidí, co ke mně chodí, nezačínala ve formě. Začali tím, že přišli — a zůstali, protože to dávalo smysl.</p>
            <ol class="fo-who__list">
              {prokoho.map((x, i) => (
                <li class="fo-who__item">
                  <span class="fo-who__no" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
                  <span class="fo-who__txt">{x}</span>
                </li>
              ))}
            </ol>
          </div>
          <div class="fo-who__media" data-reveal>
            <figure class="fo-who__photo fo-who__photo--a">
              <Image src={fotoZacatecnik} alt="Trenér v klidu navádí začínající klientku do protažení na podložce, oba se usmívají" widths={[460, 700, 980]} sizes="(max-width: 920px) 70vw, 420px" format="webp" quality={76} loading="lazy" decoding="async" />
            </figure>
            <figure class="fo-who__photo fo-who__photo--b">
              <Image src={fotoTechnika} alt="Detail opravy techniky cviku, trenér hlídá držení těla" widths={[300, 460, 620]} sizes="(max-width: 920px) 40vw, 220px" format="webp" quality={76} loading="lazy" decoding="async" />
            </figure>
            <span class="fo-who__stat" aria-hidden="true"><b>8 let</b> praxe</span>
          </div>
        </div>
      </section>

      <!-- ████ KONTAKT ████ -->
      <section id="fo-kontakt" class="fo-section fo-contact">
        <div class="fo-wrap">
          <div class="fo-contact__inner">
            <figure class="fo-contact__photo">
              <Image src={fotoPortret} alt="Portrét osobního trenéra Tomáše ve světlém studiu, klidný a vstřícný výraz" widths={[460, 700, 980]} sizes="(max-width: 920px) 92vw, 420px" format="webp" quality={80} loading="lazy" decoding="async" />
              <figcaption class="fo-contact__cap">{trener.jmeno}, váš trenér</figcaption>
            </figure>
            <div class="fo-contact__panel">
              <div>
                <p class="fo-kicker fo-kicker--lime">První trénink</p>
                <h2 class="fo-contact__title">Pojďme začít<br />tréninkem na&nbsp;zkoušku</h2>
                <p class="fo-contact__lead">Napište nebo zavolejte. Ozvu se vám já, ne recepce — domluvíme termín, v klidu projdeme cíl a první trénink bez závazku vyzkoušíme.</p>
                <p class="fo-contact__sign">— {trener.jmeno}</p>
              </div>
              <div class="fo-contact__details">
                <a class="fo-crow" href="tel:+420777567890"><span class="fo-crow__l">Telefon</span><span class="fo-crow__v">+420 777 567 890</span></a>
                <a class="fo-crow" href="mailto:trener.forma@example.cz"><span class="fo-crow__l">E-mail</span><span class="fo-crow__v">trener.forma@example.cz</span></a>
                <div class="fo-crow fo-crow--static"><span class="fo-crow__l">Kde</span><span class="fo-crow__v fo-crow__v--addr">Sportovní 4, České Budějovice</span></div>
                <a class="fo-btn fo-btn--solid fo-contact__btn" href="tel:+420777567890">Domluvit trénink</a>
                <p class="fo-contact__demo">Demo ukázka webu od Mossven.</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="fo-foot">
      <div class="fo-wrap fo-foot__inner">
        <div>
          <span class="fo-brand__name fo-foot__name">FORMA</span>
          <p class="fo-foot__tag">Osobní trénink na míru — vede {trener.jmeno}.</p>
        </div>
        <p class="fo-foot__note">Demo web vytvořený jako ukázka řešení od <a class="fo-foot__link" href="/">Mossven</a>.</p>
      </div>
    </footer>

    <style is:global>
      /* ═══ Forma — redesign v3 (klidná disciplína, postup 0→100), vše .fo- ═══ */
      .fo-body {
        --fo-bg: #f3efe6; --fo-panel: #fffdf8; --fo-ink: #1a1611; --fo-char: #181611;
        --fo-soft: #5c554a; --fo-faint: #978f7e; --fo-sand: #e8dfcb;
        --fo-lime: #c2ef3a; --fo-lime-deep: #6b8a0f;
        --fo-line: rgba(26,22,17,.14); --fo-line-soft: rgba(26,22,17,.07);
        --ff-display: "Big Shoulders Display", system-ui, sans-serif;
        --ff-body: "Sora", system-ui, sans-serif;
        --fo-ease: cubic-bezier(.22,.61,.36,1); --fo-maxw: 1180px; --fo-r: 16px;
        margin: 0; font-family: var(--ff-body); color: var(--fo-ink); background: var(--fo-bg);
        line-height: 1.62; -webkit-font-smoothing: antialiased; overflow-x: hidden;
      }
      /* měřicí mřížka (jemná textura značky) */
      .fo-body::before { content: ""; position: fixed; inset: 0; z-index: 0; pointer-events: none;
        background-image: linear-gradient(rgba(26,22,17,.035) 1px, transparent 1px), linear-gradient(90deg, rgba(26,22,17,.035) 1px, transparent 1px);
        background-size: 100% 56px, 56px 100%; mask-image: radial-gradient(120% 90% at 50% 0%, #000 30%, transparent 86%); }
      .fo-body > * { position: relative; z-index: 1; }
      .fo-body *, .fo-body *::before, .fo-body *::after { box-sizing: border-box; }
      .fo-wrap { max-width: var(--fo-maxw); margin: 0 auto; padding: 0 clamp(20px,4vw,40px); width: 100%; }
      .fo-body a { text-decoration: none; color: inherit; }
      .fo-body h1, .fo-body h2, .fo-body h3 { font-family: var(--ff-display); margin: 0; line-height: .84; letter-spacing: .005em; font-weight: 800; text-transform: uppercase; }
      .fo-body p { margin: 0; }
      .fo-body a:focus-visible, .fo-body button:focus-visible { outline: 3px solid var(--fo-lime-deep); outline-offset: 3px; }
      .fo-kicker { display: inline-block; font-family: var(--ff-body); font-size: .72rem; font-weight: 600; letter-spacing: .2em; text-transform: uppercase; color: var(--fo-lime-deep); margin-bottom: .9rem; }
      .fo-kicker--lime { color: var(--fo-lime); }

      /* signature: měřicí štítek sekce */
      .fo-sect-tag { display: inline-flex; align-items: center; gap: .7em; font-family: var(--ff-body); font-size: .72rem; font-weight: 600; letter-spacing: .18em; text-transform: uppercase; color: var(--fo-lime-deep); margin-bottom: 1rem; }
      .fo-sect-tag--light { color: var(--fo-lime); }
      .fo-sect-tag__tick { width: 22px; height: 0; border-top: 2px solid currentColor; position: relative; }
      .fo-sect-tag__tick::before, .fo-sect-tag__tick::after { content: ""; position: absolute; top: -4px; width: 2px; height: 8px; background: currentColor; }
      .fo-sect-tag__tick::before { left: 0; } .fo-sect-tag__tick::after { right: 0; }

      /* tlačítka */
      .fo-btn { display: inline-flex; align-items: center; justify-content: center; gap: .5em; font-family: var(--ff-display); font-weight: 700; text-transform: uppercase; letter-spacing: .04em; font-size: 1.04rem; padding: .68em 1.45em; border-radius: 10px; cursor: pointer; border: 2px solid transparent; transition: transform .15s var(--fo-ease), background-color .2s, color .2s, box-shadow .2s; }
      .fo-btn--solid { background: var(--fo-lime); color: var(--fo-ink); box-shadow: 0 12px 26px -14px rgba(107,138,15,.7); }
      .fo-btn--solid:hover { transform: translateY(-2px); background: #cef24f; }
      .fo-btn--line { background: transparent; color: var(--fo-ink); border-color: var(--fo-ink); }
      .fo-btn--line:hover { background: var(--fo-ink); color: #fff; transform: translateY(-2px); }
      .fo-btn--pill { background: var(--fo-lime); color: var(--fo-ink); border-radius: 999px; font-size: .88rem; padding: .52em 1.05em .52em 1.2em; box-shadow: 0 10px 22px -12px rgba(107,138,15,.75); }
      .fo-btn--pill:hover { background: #cef24f; transform: translateY(-1px); }
      .fo-btn__arr { font-family: var(--ff-body); font-weight: 600; transition: transform .2s var(--fo-ease); }
      .fo-btn--pill:hover .fo-btn__arr { transform: translateX(3px); }

      /* PRŮBĚŽNÁ LIŠTA POSTUPU (fixed) */
      .fo-rail { position: fixed; left: 22px; top: 50%; transform: translateY(-50%); z-index: 35; display: flex; flex-direction: column; align-items: center; gap: 12px; }
      .fo-rail__cap, .fo-rail__num { writing-mode: vertical-rl; font-family: var(--ff-body); font-size: .6rem; letter-spacing: .22em; text-transform: uppercase; color: var(--fo-faint); }
      .fo-rail__num b { font-family: var(--ff-display); font-size: .95rem; color: var(--fo-ink); font-variant-numeric: tabular-nums; }
      .fo-rail__track { position: relative; width: 4px; height: 210px; background: var(--fo-line-soft); border-radius: 999px; overflow: visible; }
      .fo-rail__tick { position: absolute; left: 50%; width: 9px; height: 1px; background: var(--fo-line); transform: translate(-50%, -50%); }
      .fo-rail__fill { position: absolute; left: 0; top: 0; width: 100%; height: 100%; border-radius: 999px; background: linear-gradient(180deg, var(--fo-lime), var(--fo-lime-deep)); transform: scaleY(0); transform-origin: top; transition: transform .12s linear; }
      @media (max-width: 1320px) { .fo-rail { display: none; } }

      /* TOP */
      .fo-top { position: sticky; top: 0; z-index: 40; background: color-mix(in srgb, var(--fo-bg) 86%, transparent); backdrop-filter: blur(10px); border-bottom: 1px solid var(--fo-line-soft); }
      .fo-top__inner { display: flex; align-items: center; gap: 18px; height: 62px; }
      .fo-brand { display: inline-flex; align-items: baseline; gap: .55em; }
      .fo-brand__name { font-family: var(--ff-display); font-weight: 900; font-size: 1.55rem; letter-spacing: .02em; }
      .fo-brand__sub { font-size: .68rem; letter-spacing: .12em; text-transform: uppercase; color: var(--fo-faint); }
      .fo-top__nav { display: flex; gap: 24px; margin: 0 auto; font-size: .8rem; font-weight: 600; letter-spacing: .04em; text-transform: uppercase; }
      .fo-top__nav a { position: relative; color: var(--fo-soft); padding: 2px 0; transition: color .2s; }
      .fo-top__nav a::after { content: ""; position: absolute; left: 0; right: 100%; bottom: -2px; height: 2px; background: var(--fo-lime-deep); transition: right .25s var(--fo-ease); }
      .fo-top__nav a:hover { color: var(--fo-ink); }
      .fo-top__nav a:hover::after { right: 0; }

      /* HERO */
      .fo-hero { padding: clamp(34px,5vw,76px) 0 clamp(44px,6vw,80px); }
      .fo-hero__grid { display: grid; grid-template-columns: 1.08fr .92fr; gap: clamp(28px,4vw,56px); align-items: center; }
      .fo-eyebrow { display: inline-flex; align-items: center; gap: .6em; font-size: .76rem; font-weight: 600; letter-spacing: .14em; text-transform: uppercase; color: var(--fo-soft); margin-bottom: 1.2rem; }
      .fo-eyebrow__dot { width: 9px; height: 9px; border-radius: 50%; flex: none; background: var(--fo-lime); box-shadow: 0 0 0 4px rgba(194,239,58,.3); }
      .fo-hero__title { font-size: clamp(3.3rem,11vw,7.4rem); font-weight: 900; line-height: .8; letter-spacing: -.01em; }
      .fo-hero__title span { display: block; }
      .fo-hero__formy { display: inline; color: var(--fo-lime-deep); }
      .fo-hero__title-em { color: var(--fo-ink); }
      .fo-hero__sub { margin-top: 1.5rem; font-size: clamp(1.04rem,1.5vw,1.18rem); color: var(--fo-soft); max-width: 32em; }
      .fo-hero__cta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 1.8rem; }
      .fo-hero__sign { margin-top: 1.5rem; padding-top: 1.2rem; border-top: 1px solid var(--fo-line-soft); font-size: .9rem; color: var(--fo-soft); }

      /* DASHBOARD */
      .fo-dash { position: relative; background: var(--fo-panel); border: 1px solid var(--fo-line); border-radius: 20px; overflow: hidden; box-shadow: 0 50px 90px -50px rgba(26,22,17,.6); }
      .fo-dash__photo { position: relative; margin: 0; line-height: 0; }
      .fo-dash__photo img { display: block; width: 100%; height: 100%; aspect-ratio: 16 / 9; object-fit: cover; filter: saturate(1.02) contrast(1.02); }
      .fo-dash__live { position: absolute; top: 14px; right: 14px; width: 10px; height: 10px; border-radius: 50%; background: var(--fo-lime); box-shadow: 0 0 0 0 rgba(194,239,58,.7); animation: fo-pulse 2.2s var(--fo-ease) infinite; }
      @keyframes fo-pulse { 0% { box-shadow: 0 0 0 0 rgba(194,239,58,.6); } 70% { box-shadow: 0 0 0 9px rgba(194,239,58,0); } 100% { box-shadow: 0 0 0 0 rgba(194,239,58,0); } }
      .fo-dash__name { position: absolute; left: 12px; top: 12px; font-family: var(--ff-display); font-weight: 700; text-transform: uppercase; letter-spacing: .04em; font-size: .76rem; color: var(--fo-ink); background: var(--fo-lime); padding: 4px 11px; border-radius: 999px; }
      .fo-dash__body { padding: clamp(18px,2.4vw,24px); display: grid; gap: 16px; }
      .fo-dash__head { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; }
      .fo-dash__klabel { font-size: .66rem; font-weight: 600; letter-spacing: .16em; text-transform: uppercase; color: var(--fo-lime-deep); }
      .fo-dash__wk { font-family: var(--ff-display); font-weight: 800; font-size: 1.1rem; }
      .fo-dash__rlabel { display: block; font-size: .62rem; font-weight: 600; letter-spacing: .16em; text-transform: uppercase; color: var(--fo-faint); margin-bottom: 9px; }

      .fo-prog2__bar { position: relative; height: 12px; background: var(--fo-line-soft); border-radius: 999px; overflow: hidden; }
      .fo-prog2__fill { position: relative; display: block; height: 100%; width: 0; border-radius: 999px; background: linear-gradient(90deg, var(--fo-lime-deep), var(--fo-lime)); animation: fo-fill 1.5s var(--fo-ease) .3s forwards; }
      @keyframes fo-fill { to { width: var(--p); } }
      .fo-prog2__knob { position: absolute; right: -2px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; border-radius: 50%; background: #fff; border: 3px solid var(--fo-lime-deep); box-shadow: 0 3px 8px rgba(26,22,17,.3); }
      .fo-prog2__scale { display: flex; justify-content: space-between; margin-top: 6px; font-size: .58rem; letter-spacing: .08em; color: var(--fo-faint); font-variant-numeric: tabular-nums; }
      .fo-prog2__val { margin-top: 4px; display: flex; align-items: baseline; gap: 6px; }
      .fo-prog2__val b { font-family: var(--ff-display); font-weight: 900; font-size: 2.2rem; line-height: 1; font-variant-numeric: tabular-nums; }
      .fo-prog2__val span { font-size: .82rem; color: var(--fo-faint); }

      .fo-dash__next, .fo-dash__mini { border-top: 1px solid var(--fo-line-soft); padding-top: 14px; }
      .fo-dash__nrow { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; }
      .fo-dash__nday { font-family: var(--ff-display); font-weight: 800; font-size: 1.15rem; margin-right: 4px; }
      .fo-pill { display: inline-flex; align-items: center; gap: .4em; font-family: var(--ff-body); font-size: .74rem; font-weight: 600; letter-spacing: .04em; padding: 5px 11px; border-radius: 999px; border: 1px solid var(--fo-line); }
      .fo-pill--lime { background: var(--fo-lime); border-color: transparent; color: var(--fo-ink); }
      .fo-pill--time { font-variant-numeric: tabular-nums; color: var(--fo-soft); }
      .fo-pill__dot { width: 6px; height: 6px; border-radius: 50%; background: var(--fo-lime-deep); animation: fo-blink 1.4s steps(2) infinite; }
      @keyframes fo-blink { 50% { opacity: .25; } }

      .fo-mini { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(7, 1fr); gap: 6px; align-items: end; }
      .fo-mini__d { display: grid; gap: 5px; justify-items: center; }
      .fo-mini__bar { width: 100%; max-width: 18px; height: var(--h); min-height: 5px; border-radius: 3px; background: var(--fo-line); }
      .fo-mini__lab { font-size: .58rem; letter-spacing: .04em; color: var(--fo-faint); text-transform: uppercase; }
      .fo-mini__d--silne .fo-mini__bar { background: var(--fo-lime-deep); }
      .fo-mini__d--stred .fo-mini__bar { background: var(--fo-lime); }
      .fo-mini__d--mekke .fo-mini__bar, .fo-mini__d--lehke .fo-mini__bar { background: #c9d79a; }
      .fo-mini__d--volno .fo-mini__bar { background: var(--fo-line); opacity: .55; }

      .fo-dash__notes { list-style: none; margin: 0; padding: 14px 0 0; border-top: 1px solid var(--fo-line-soft); display: grid; gap: 8px; }
      .fo-dash__notes li { display: flex; align-items: center; gap: 10px; font-size: .9rem; color: var(--fo-soft); }
      .fo-note__ic { width: 20px; height: 20px; flex: none; display: grid; place-items: center; border-radius: 6px; background: var(--fo-sand); color: var(--fo-lime-deep); font-size: .8rem; font-weight: 700; }
      .fo-note__ic--up { background: var(--fo-lime); color: var(--fo-ink); }

      /* MILNÍKY */
      .fo-mile-sec { padding: clamp(30px,4vw,52px) 0 clamp(44px,6vw,76px); }
      .fo-mile { position: relative; list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(4, 1fr); gap: clamp(16px,2.4vw,32px); }
      .fo-mile__line { position: absolute; top: 8px; left: 8px; right: 8px; height: 2px; background: repeating-linear-gradient(90deg, var(--fo-line) 0 6px, transparent 6px 12px); }
      .fo-mile__item { position: relative; padding-top: 30px; }
      .fo-mile__dot { position: absolute; top: 1px; left: 0; width: 16px; height: 16px; border-radius: 50%; background: var(--fo-lime); border: 3px solid var(--fo-bg); box-shadow: 0 0 0 1px var(--fo-line); }
      .fo-mile__k { font-family: var(--ff-display); font-weight: 900; font-size: clamp(2rem,4vw,3rem); line-height: 1; }
      .fo-mile__t { display: block; margin-top: 2px; font-family: var(--ff-display); font-weight: 700; text-transform: uppercase; letter-spacing: .04em; font-size: 1.05rem; color: var(--fo-lime-deep); }
      .fo-mile__d { display: block; margin-top: .7rem; font-size: .94rem; color: var(--fo-soft); }

      /* SECTION shared */
      .fo-section { padding: clamp(60px,9vw,120px) 0; position: relative; }
      .fo-head { margin-bottom: clamp(34px,5vw,60px); }
      .fo-head--split { display: grid; grid-template-columns: 1fr .82fr; gap: clamp(20px,4vw,52px); align-items: end; }
      .fo-head__title { font-size: clamp(2.2rem,6vw,4.4rem); font-weight: 800; }
      .fo-head__title--light { color: var(--fo-bg); }
      .fo-head__aside { font-size: 1.02rem; color: var(--fo-soft); max-width: 34em; align-self: end; }
      .fo-head__aside--light { color: #cfd2c4; }

      /* PROGRAMY — karty */
      .fo-cards { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(16px,2vw,24px); }
      .fo-card { display: flex; flex-direction: column; background: var(--fo-panel); border: 1px solid var(--fo-line); border-radius: var(--fo-r); overflow: hidden; box-shadow: 0 24px 50px -38px rgba(26,22,17,.5); transition: transform .25s var(--fo-ease), box-shadow .25s, border-color .25s; }
      .fo-card:hover { transform: translateY(-6px); border-color: var(--fo-lime-deep); box-shadow: 0 40px 70px -40px rgba(26,22,17,.55), 0 0 0 3px rgba(194,239,58,.35); }
      .fo-card__media { position: relative; margin: 0; line-height: 0; overflow: hidden; }
      .fo-card__media img { display: block; width: 100%; height: 100%; aspect-ratio: 16 / 11; object-fit: cover; transition: transform .5s var(--fo-ease); }
      .fo-card:hover .fo-card__media img { transform: scale(1.05); }
      .fo-card__kod { position: absolute; left: 12px; bottom: -6px; font-family: var(--ff-display); font-weight: 900; font-size: clamp(3.4rem,7vw,4.6rem); line-height: 1; color: #fff; -webkit-text-stroke: 2px rgba(26,22,17,.55); text-stroke: 2px rgba(26,22,17,.55); }
      .fo-card__body { display: flex; flex-direction: column; flex: 1; padding: clamp(20px,2.4vw,26px); }
      .fo-card__tag { align-self: flex-start; font-family: var(--ff-body); font-size: .66rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; color: var(--fo-lime-deep); background: var(--fo-sand); padding: 5px 10px; border-radius: 999px; margin-bottom: .8rem; }
      .fo-card__nazev { font-size: clamp(1.6rem,2.6vw,2rem); font-weight: 800; }
      .fo-card__popis { margin-top: .6rem; color: var(--fo-soft); font-size: .98rem; flex: 1; }
      .fo-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 1.2rem; padding-top: 1.1rem; border-top: 1px solid var(--fo-line-soft); }
      .fo-chip { display: inline-flex; flex-direction: column; gap: 1px; padding: 7px 12px; border: 1px solid var(--fo-line); border-radius: 9px; background: color-mix(in srgb, var(--fo-sand) 35%, var(--fo-panel)); }
      .fo-chip__k { font-size: .56rem; letter-spacing: .12em; text-transform: uppercase; color: var(--fo-faint); }
      .fo-chip__v { font-family: var(--ff-display); font-weight: 700; font-size: 1rem; }
      .fo-chip--price { border-color: var(--fo-lime-deep); background: var(--fo-lime); }
      .fo-chip--price .fo-chip__k { color: rgba(26,22,17,.6); }
      .fo-chip--price .fo-chip__v { color: var(--fo-ink); }
      .fo-programs__note { margin-top: clamp(20px,3vw,30px); color: var(--fo-faint); font-size: .9rem; }

      /* CO SPOLU SLEDUJEME */
      .fo-pcards { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(14px,2vw,22px); }
      .fo-pcard { background: var(--fo-panel); border: 1px solid var(--fo-line); border-radius: 14px; box-shadow: 0 24px 48px -34px rgba(26,22,17,.5); }
      .fo-pcard--lg { padding: clamp(22px,3vw,30px); display: flex; flex-direction: column; }
      .fo-pcard__label { font-family: var(--ff-body); font-size: .68rem; font-weight: 600; letter-spacing: .16em; text-transform: uppercase; color: var(--fo-lime-deep); margin-bottom: .5rem; }
      .fo-pcard__val { font-family: var(--ff-display); font-weight: 900; font-size: clamp(2.4rem,5vw,3.4rem); line-height: .9; }
      .fo-pcard__val small { display: inline-block; font-size: .9rem; font-weight: 700; color: var(--fo-soft); }
      .fo-track { height: 10px; margin-top: 16px; background: var(--fo-line-soft); border-radius: 999px; overflow: hidden; }
      .fo-track__fill { display: block; height: 100%; width: var(--p); border-radius: 999px; background: linear-gradient(90deg, var(--fo-lime-deep), var(--fo-lime)); }
      .fo-pcard__cap { display: block; margin-top: 14px; font-size: .86rem; color: var(--fo-soft); }
      [data-reveal] .fo-pcard--lg .fo-track__fill { width: 0; transition: width 1.1s var(--fo-ease) .25s; }
      [data-reveal].fo-in .fo-pcard--lg .fo-track__fill { width: var(--p); }

      /* TÝDEN — kalendář */
      .fo-week { background: var(--fo-char); border-radius: clamp(18px,3vw,30px); position: relative; overflow: hidden; }
      .fo-week::before { content: ""; position: absolute; inset: 0; pointer-events: none; opacity: .5;
        background-image: radial-gradient(rgba(255,255,255,.05) 1px, transparent 1.4px); background-size: 14px 14px; }
      .fo-week > .fo-wrap { position: relative; }
      .fo-cal { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(7, 1fr); gap: clamp(8px,1.2vw,12px); }
      .fo-cell { display: flex; flex-direction: column; gap: 9px; min-height: 168px; padding: 16px 12px; border-radius: 12px; border: 1px solid rgba(255,255,255,.1); background: rgba(255,255,255,.03); }
      .fo-cell__d { font-family: var(--ff-display); font-weight: 800; font-size: 1.5rem; color: #f3efe6; }
      .fo-cell__dots { display: flex; gap: 4px; }
      .fo-cell__dots i { width: 7px; height: 7px; border-radius: 50%; background: rgba(255,255,255,.16); }
      .fo-cell__dots i.on { background: var(--fo-lime); }
      .fo-cell__t { margin-top: auto; font-family: var(--ff-display); font-weight: 700; text-transform: uppercase; letter-spacing: .04em; font-size: 1.05rem; color: var(--fo-lime); }
      .fo-cell__note { font-size: .72rem; color: rgba(243,239,230,.55); }
      .fo-cell--silne { background: rgba(194,239,58,.1); border-color: rgba(194,239,58,.4); border-left: 4px solid var(--fo-lime); }
      .fo-cell--silne .fo-cell__d { color: #fff; }
      .fo-cell--stred { border-color: rgba(194,239,58,.22); }
      .fo-cell--mekke .fo-cell__t, .fo-cell--lehke .fo-cell__t { color: #c9d79a; }
      .fo-cell--volno { background: transparent; border-style: dashed; border-color: rgba(255,255,255,.14); }
      .fo-cell--volno .fo-cell__d { color: rgba(243,239,230,.5); }
      .fo-cell--volno .fo-cell__t { color: var(--fo-faint); }
      .fo-week__note { margin-top: clamp(22px,3vw,32px); color: var(--fo-faint); font-size: .9rem; }

      /* PRO KOHO */
      .fo-who__inner { display: grid; grid-template-columns: 1.02fr .98fr; gap: clamp(28px,5vw,72px); align-items: center; }
      .fo-who__h { font-size: clamp(2rem,5vw,3.6rem); font-weight: 800; margin-top: .2rem; }
      .fo-who__h em { font-style: normal; color: var(--fo-lime-deep); }
      .fo-who__lead { margin-top: 1.1rem; color: var(--fo-soft); font-size: 1.06rem; max-width: 30em; }
      .fo-who__list { list-style: none; margin: clamp(22px,3vw,34px) 0 0; padding: 0; }
      .fo-who__item { display: grid; grid-template-columns: auto 1fr; gap: 16px; align-items: baseline; padding: 16px 0; border-top: 1px solid var(--fo-line); font-size: 1.06rem; }
      .fo-who__item:last-child { border-bottom: 1px solid var(--fo-line); }
      .fo-who__no { font-family: var(--ff-display); font-weight: 800; font-size: 1.2rem; color: var(--fo-lime-deep); font-variant-numeric: tabular-nums; }
      .fo-who__media { position: relative; padding-bottom: 40px; }
      .fo-who__photo { margin: 0; border-radius: var(--fo-r); overflow: hidden; border: 1px solid var(--fo-line); line-height: 0; box-shadow: 0 30px 56px -40px rgba(26,22,17,.5); }
      .fo-who__photo--a img { display: block; width: 100%; height: 100%; aspect-ratio: 4 / 3; object-fit: cover; }
      .fo-who__photo--b { position: absolute; right: -14px; bottom: 0; width: 44%; border: 5px solid var(--fo-bg); border-radius: 14px; }
      .fo-who__photo--b img { display: block; width: 100%; height: 100%; aspect-ratio: 1 / 1; object-fit: cover; }
      .fo-who__stat { position: absolute; left: -8px; top: -18px; background: var(--fo-lime); color: var(--fo-ink); font-family: var(--ff-display); font-weight: 700; text-transform: uppercase; letter-spacing: .04em; font-size: .82rem; padding: 8px 14px; border-radius: 999px; box-shadow: 0 14px 26px -16px rgba(26,22,17,.6); }
      .fo-who__stat b { font-size: 1.04rem; }

      /* KONTAKT */
      .fo-contact__inner { display: grid; grid-template-columns: .72fr 1fr; gap: clamp(18px,3vw,30px); align-items: stretch; }
      .fo-contact__photo { position: relative; margin: 0; border-radius: var(--fo-r); overflow: hidden; border: 1px solid var(--fo-line); line-height: 0; min-height: 100%; }
      .fo-contact__photo img { display: block; width: 100%; height: 100%; min-height: 340px; object-fit: cover; object-position: center 20%; }
      .fo-contact__cap { position: absolute; left: 12px; bottom: 12px; font-family: var(--ff-display); font-weight: 700; text-transform: uppercase; letter-spacing: .04em; font-size: .8rem; color: var(--fo-ink); background: var(--fo-lime); padding: 5px 12px; border-radius: 999px; }
      .fo-contact__panel { display: grid; grid-template-columns: 1.06fr .94fr; gap: clamp(24px,4vw,48px); background: var(--fo-ink); color: var(--fo-bg); border-radius: var(--fo-r); padding: clamp(28px,4vw,52px); }
      .fo-contact__title { color: #fff; font-size: clamp(1.9rem,4vw,3rem); }
      .fo-contact__lead { margin-top: 1rem; color: #cfcbc0; max-width: 26em; }
      .fo-contact__sign { margin-top: 1rem; font-family: var(--ff-display); font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--fo-lime); font-size: 1.1rem; }
      .fo-contact__details { display: flex; flex-direction: column; gap: 12px; justify-content: center; }
      .fo-crow { display: flex; flex-direction: column; gap: 2px; padding: 14px 16px; border: 1px solid rgba(243,239,230,.16); border-radius: 10px; transition: border-color .2s, background-color .2s; }
      a.fo-crow:hover { border-color: var(--fo-lime); background: rgba(243,239,230,.05); }
      .fo-crow__l { font-size: .64rem; letter-spacing: .16em; text-transform: uppercase; color: var(--fo-lime); }
      .fo-crow__v { font-family: var(--ff-display); font-weight: 700; font-size: 1.3rem; }
      .fo-crow__v--addr { font-size: 1.05rem; }
      .fo-contact__btn { margin-top: 4px; }
      .fo-contact__demo { color: #9a9d8f; font-size: .78rem; margin-top: 6px; }

      /* FOOTER */
      .fo-foot { border-top: 1px solid var(--fo-line); padding: 32px 0; }
      .fo-foot__inner { display: flex; flex-wrap: wrap; gap: 16px 28px; align-items: center; justify-content: space-between; }
      .fo-foot__name { font-size: 1.3rem; }
      .fo-foot__tag { color: var(--fo-soft); font-size: .92rem; margin-top: 2px; }
      .fo-foot__note { color: var(--fo-soft); font-size: .92rem; }
      .fo-foot__link { color: var(--fo-lime-deep); font-weight: 600; border-bottom: 2px solid var(--fo-lime-deep); }

      /* reveal */
      [data-reveal] { opacity: 0; transform: translateY(26px); transition: opacity .7s var(--fo-ease), transform .7s var(--fo-ease); }
      [data-reveal].fo-in { opacity: 1; transform: none; }

      @media (max-width: 980px) {
        .fo-hero__grid { grid-template-columns: 1fr; }
        .fo-dash { order: -1; max-width: 440px; }
        .fo-head--split { grid-template-columns: 1fr; align-items: start; }
        .fo-mile { grid-template-columns: repeat(2, 1fr); gap: 30px 24px; }
        .fo-mile__line { display: none; }
        .fo-cards { grid-template-columns: 1fr; max-width: 440px; }
        .fo-pcards { grid-template-columns: 1fr; max-width: 460px; }
        .fo-cal { grid-template-columns: repeat(4, 1fr); }
        .fo-who__inner { grid-template-columns: 1fr; }
        .fo-who__media { max-width: 520px; }
        .fo-contact__inner { grid-template-columns: 1fr; }
        .fo-contact__photo img { min-height: 280px; max-height: 380px; }
        .fo-contact__panel { grid-template-columns: 1fr; }
      }
      @media (max-width: 680px) {
        .fo-top__nav { display: none; }
        .fo-mile { grid-template-columns: 1fr; gap: 22px; }
        .fo-cal { grid-template-columns: repeat(2, 1fr); }
        .fo-cell { min-height: 140px; }
        .fo-foot__inner { flex-direction: column; align-items: flex-start; }
      }
      @media (prefers-reduced-motion: reduce) {
        .fo-body * { animation: none !important; transition: none !important; }
        .fo-prog2__fill { width: var(--p); }
        [data-reveal] .fo-pcard--lg .fo-track__fill { width: var(--p); }
        [data-reveal] { opacity: 1; transform: none; }
      }
    </style>

    <script is:inline>
      (function () {
        var reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
        var els = document.querySelectorAll("[data-reveal]");
        if (!("IntersectionObserver" in window) || reduce) {
          els.forEach(function (el) { el.classList.add("fo-in"); });
        } else {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add("fo-in"); io.unobserve(e.target); } });
          }, { threshold: 0.12, rootMargin: "0px 0px -8% 0px" });
          els.forEach(function (el) { io.observe(el); });
        }

        var fill = document.querySelector(".fo-rail__fill");
        var num = document.getElementById("fo-railnum");
        var ticking = false;
        function upd() {
          var max = document.documentElement.scrollHeight - window.innerHeight;
          var p = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
          if (fill) fill.style.transform = "scaleY(" + p + ")";
          if (num) num.textContent = Math.round(p * 100);
          ticking = false;
        }
        addEventListener("scroll", function () { if (!ticking) { ticking = true; requestAnimationFrame(upd); } }, { passive: true });
        upd();

        var c = document.getElementById("fo-count");
        if (c && !reduce) {
          var to = parseInt(c.getAttribute("data-to"), 10) || 0, start = null;
          function step(ts) {
            if (!start) start = ts;
            var t = Math.min(1, (ts - start) / 1500);
            c.textContent = Math.round((1 - Math.pow(1 - t, 3)) * to);
            if (t < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        } else if (c) { c.textContent = c.getAttribute("data-to"); }
      })();
    </script>
  </body>
</html>
