---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Mossven \u2014 Weby, hosting a p\u00e9\u010de, kter\u00e9 ti\u0161e funguj\u00ed",
  description = "Postav\u00edm v\u00e1m web, nastav\u00edm dom\u00e9nu, hosting, SSL a z\u00e1lohy a po spu\u0161t\u011bn\u00ed se o web d\u00e1l star\u00e1m. Vy \u0159e\u0161\u00edte z\u00e1kazn\u00edky, ne techniku.",
} = Astro.props;
---
<!doctype html>
<html lang="cs" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <!-- Set theme + language before paint to avoid a flash -->
    <script is:inline>
      try {
        var t = localStorage.getItem("mv-theme") || "dark";
        var l = localStorage.getItem("mv-lang") || "cs";
        document.documentElement.setAttribute("data-theme", t);
        document.documentElement.setAttribute("lang", l);
      } catch (e) {}
    </script>
  </head>
  <body>
    <canvas id="fly"></canvas>
    <Header />
    <a id="top"></a>
    <slot />
    <Footer />
    <script>
      import "../scripts/app.ts";
    </script>
  </body>
</html>
