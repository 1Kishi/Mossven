<section class="sec" id="kontakt">
  <div class="wrap contact">
    <div class="reveal">
      <div class="kicker mono" data-i18n="ct.kicker" style="color:var(--status)">Kontakt</div>
      <h2 style="font-size:clamp(1.9rem,3.6vw,2.7rem);margin-top:.9rem" data-i18n="ct.h">Povězte mi, co má váš web zvládnout.</h2>
      <p style="color:var(--ink-soft);margin-top:1.1rem;font-size:1.05rem" data-i18n="ct.p">Napište pár vět. Ozvu se do jednoho pracovního dne s návrhem i cenou. Nezávazně.</p>
      <div class="antistress" data-i18n="ct.anti">Nevíte přesně, co potřebujete? To nevadí. Napište mi, co děláte a co by měl web přibližně řešit. Podívám se na to a navrhnu nejjednodušší rozumné řešení. Bez tlaku, bez technických řečí.</div>
      <p class="freecheck"><span data-i18n="ct.free1">Máte starý web?</span> <a href="#kontakt" data-i18n="ct.free2">Pošlete mi odkaz a zdarma vám řeknu ve 3 bodech, co bych zlepšil.</a></p>
    </div>
    <form class="form reveal" id="cform" novalidate>
      <div class="success" id="ok" data-i18n="ct.ok">Poptávka dorazila. Ozvu se do jednoho pracovního dne.</div>
      <div class="field half"><label data-i18n="ct.name">Jméno</label><input type="text" name="name" required /></div>
      <div class="field half"><label data-i18n="ct.email">E-mail</label><input type="email" name="email" required /></div>
      <div class="field half"><label data-i18n="ct.phone">Telefon</label><input type="tel" name="phone" /></div>
      <div class="field half"><label data-i18n="ct.need">Co potřebujete?</label>
        <select name="need"><option value="new_website" data-i18n="ct.need.o0">Nový web</option><option value="website_care" data-i18n="ct.need.o1">Web + péče</option><option value="existing_care" data-i18n="ct.need.o2">Jen péče o stávající web</option><option value="other" data-i18n="ct.need.o3">Něco jiného</option></select></div>
      <div class="field half"><label data-i18n="ct.budget">Rozpočet / představa ceny</label>
        <select name="budget"><option value="under_15000" data-i18n="ct.budget.o0">do 15 000 Kč</option><option value="15000_30000" data-i18n="ct.budget.o1">15–30 000 Kč</option><option value="30000_50000" data-i18n="ct.budget.o2">30–50 000 Kč</option><option value="unknown" data-i18n="ct.budget.o3">nevím, chci poradit</option></select></div>
      <div class="field half"><label data-i18n="ct.when">Kdy web potřebujete?</label>
        <select name="when"><option value="asap" data-i18n="ct.when.o0">co nejdříve</option><option value="within_month" data-i18n="ct.when.o1">během měsíce</option><option value="two_three_months" data-i18n="ct.when.o2">během 2–3 měsíců</option><option value="researching" data-i18n="ct.when.o3">zatím jen zjišťuji možnosti</option></select></div>
      <div class="field half"><label data-i18n="ct.has">Už máte web?</label>
        <select name="hasweb"><option value="0" data-i18n="ct.yn.no">Ne</option><option value="1" data-i18n="ct.yn.yes">Ano</option></select></div>
      <div class="field half"><label data-i18n="ct.dom">Už máte doménu?</label>
        <select name="hasdomain"><option value="0" data-i18n="ct.yn.no">Ne</option><option value="1" data-i18n="ct.yn.yes">Ano</option></select></div>
      <div class="field"><label data-i18n="ct.url">Současný web (pokud máte)</label><input type="url" name="url" placeholder="https://" /></div>
      <div class="field"><label data-i18n="ct.pref">Preferovaný kontakt</label>
        <div class="radios"><label><input type="radio" name="pref" value="phone" checked /> <span data-i18n="ct.pref.phone">Telefonicky</span></label><label><input type="radio" name="pref" value="email" /> <span data-i18n="ct.pref.email">E-mailem</span></label></div></div>
      <div class="field"><label data-i18n="ct.msg">Krátká zpráva</label><textarea name="message"></textarea></div>
      <div class="field consent"><input type="checkbox" name="consent" id="consent" required /><label for="consent" style="margin:0;font-weight:500" data-i18n="ct.consent">Souhlasím se zpracováním údajů za účelem odpovědi na poptávku.</label></div>
      <button type="submit" class="btn btn-primary" data-i18n="ct.btn">Odeslat poptávku</button>
    </form>
  </div>
</section>
