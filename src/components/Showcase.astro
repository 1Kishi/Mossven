---
// "Ukázky" — showcase of demo sites Mossven has built, split into two
// categories: single-page "landing" sites (live) and multi-page sites.
// Single-page previews are pure CSS/SVG; live multi-page demos can carry
// a real screenshot/photo (e.g. Studio Luma's hero). Demos marked
// "Připravujeme" stay non-linked until their pages exist.

import { Image } from "astro:assets";
import lumaHero from "../pages/ukazky/kadernictvi/hero-salon.png";

const landing = [
  {
    href: "/ukazky/truhlar",
    url: "mossven.cz/ukazky/truhlar",
    tag: "demos.1t", tagFallback: "Truhlářství",
    h: "demos.1h", hFallback: "Dílna Vorel",
    p: "demos.1p", pFallback: "Nábytek na míru — vestavěné skříně, stoly, kuchyňské prvky a opravy.",
    prev: "wood", aria: "Otevřít ukázku — Dílna Vorel, truhlářství",
  },
  {
    href: "/ukazky/kavarna",
    url: "mossven.cz/ukazky/kavarna",
    tag: "demos.4t", tagFallback: "Kavárna",
    h: "demos.4h", hFallback: "Kavárna Zrnko",
    p: "demos.4p", pFallback: "Menu, otevírací doba a cesta k vám. Útulně a přehledně.",
    prev: "cafe", aria: "Otevřít ukázku — Kavárna Zrnko",
  },
  {
    href: "/ukazky/trener",
    url: "mossven.cz/ukazky/trener",
    tag: "demos.5t", tagFallback: "Osobní trénink",
    h: "demos.5h", hFallback: "Forma",
    p: "demos.5p", pFallback: "Programy, týdenní rytmus a první trénink na zkoušku.",
    prev: "fit", aria: "Otevřít ukázku — Forma, osobní trénink",
  },
];

const multi = [
  {
    href: "/ukazky/kadernictvi",
    url: "mossven.cz/ukazky/kadernictvi",
    tag: "demos.2t", tagFallback: "Kadeřnictví",
    h: "demos.2h", hFallback: "Studio Luma",
    p: "demos.2p", pFallback: "Barva, střih, rezervace, galerie a tým — na více stránkách.",
    prev: "salon", aria: "Otevřít ukázku — Studio Luma, kadeřnictví (vícestránkový web)",
    img: lumaHero, imgAlt: "Náhled webu Studio Luma — interiér kadeřnictví",
  },
  {
    url: "mossven.cz/ukazky/tetovani",
    tag: "demos.3t", tagFallback: "Tetování & piercing",
    h: "demos.3h", hFallback: "Ateliér Hrot",
    p: "demos.3p", pFallback: "Portfolio, služby, ceník a hygiena — jako vícestránkový web.",
    prev: "ink",
  },
];
---
<section class="sec showcase" id="ukazky">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="kicker mono" data-i18n="demos.kicker">Ukázkové weby</div>
      <h2 data-i18n="demos.h">Naše práce podle typu webu.</h2>
      <p data-i18n="demos.p">Ukázkové stránky pro smyšlené místní podniky. Každá má vlastní vizuální tvář a obsah na míru oboru.</p>
    </div>

    <!-- CATEGORY 1: landing pages (live) -->
    <div class="ux-cat reveal">
      <span class="ux-cat__num mono">01</span>
      <div>
        <h3 class="ux-cat__h" data-i18n="demos.cat1">Jednostránkové weby</h3>
        <p class="ux-cat__s" data-i18n="demos.cat1s">Jedna stránka, jeden jasný cíl — ideální pro službu nebo živnost.</p>
      </div>
    </div>
    <div class="ux-grid">
      {landing.map((c) => (
        <a class="ux-card ux-card--live reveal" href={c.href} aria-label={c.aria}>
          <div class="ux-frame">
            <div class="ux-bar">
              <span class="ux-dot"></span><span class="ux-dot"></span><span class="ux-dot"></span>
              <span class="ux-url mono">{c.url}</span>
            </div>
            <div class={`ux-prev ux-prev--${c.prev}`}>
              {c.prev === "wood" && (
                <svg viewBox="0 0 220 130" aria-hidden="true" class="ux-art">
                  <rect x="34" y="44" width="118" height="10" rx="1.5" class="ux-ln ux-ln--ink"/>
                  <rect x="46" y="54" width="8" height="46" class="ux-ln ux-ln--ink"/>
                  <rect x="132" y="54" width="8" height="46" class="ux-ln ux-ln--ink"/>
                  <line x1="54" y1="64" x2="132" y2="64" class="ux-ln ux-ln--ink"/>
                  <line x1="28" y1="100" x2="158" y2="100" class="ux-ln"/>
                  <line x1="34" y1="36" x2="152" y2="36" class="ux-ln ux-ln--accent"/>
                </svg>
              )}
              {c.prev === "cafe" && (
                <svg viewBox="0 0 220 130" aria-hidden="true" class="ux-art">
                  <path d="M74 54 h54 v16 a27 27 0 0 1 -27 27 a27 27 0 0 1 -27 -27 z" class="ux-ln ux-ln--ink"/>
                  <path d="M128 60 a15 15 0 0 1 0 28" class="ux-ln"/>
                  <ellipse cx="101" cy="60" rx="23" ry="5.5" class="ux-ln ux-ln--accent ux-fill"/>
                  <line x1="84" y1="42" x2="84" y2="34" class="ux-ln"/>
                  <line x1="101" y1="42" x2="101" y2="32" class="ux-ln"/>
                  <line x1="118" y1="42" x2="118" y2="34" class="ux-ln"/>
                </svg>
              )}
              {c.prev === "fit" && (
                <svg viewBox="0 0 220 130" aria-hidden="true" class="ux-art">
                  <rect x="40" y="58" width="14" height="14" rx="2" class="ux-ln ux-ln--ink ux-fill"/>
                  <rect x="166" y="58" width="14" height="14" rx="2" class="ux-ln ux-ln--ink ux-fill"/>
                  <rect x="54" y="62" width="112" height="6" rx="3" class="ux-ln ux-ln--accent ux-fill"/>
                  <path d="M40 96 l28 -10 l30 12 l34 -20 l38 8" class="ux-ln ux-ln--accent"/>
                </svg>
              )}
              <span class="ux-badge mono">DEMO</span>
            </div>
          </div>
          <div class="ux-meta">
            <span class="kicker mono ux-tag" data-i18n={c.tag}>{c.tagFallback}</span>
            <h4 class="ux-name" data-i18n={c.h}>{c.hFallback}</h4>
            <p data-i18n={c.p}>{c.pFallback}</p>
            <span class="ux-go"><span data-i18n="demos.live">Prohlédnout ukázku</span><span class="ux-arrow" aria-hidden="true">→</span></span>
          </div>
        </a>
      ))}
    </div>

    <!-- CATEGORY 2: multi-page (in preparation) -->
    <div class="ux-cat ux-cat--mt reveal">
      <span class="ux-cat__num mono">02</span>
      <div>
        <h3 class="ux-cat__h" data-i18n="demos.cat2">Vícestránkové weby</h3>
        <p class="ux-cat__s" data-i18n="demos.cat2s">Více sekcí: galerie, ceník, tým, blog. Pro obory, které potřebují víc prostoru.</p>
      </div>
    </div>
    <div class="ux-grid ux-grid--2">
      {multi.map((c) => (
        c.href ? (
          <a class="ux-card ux-card--live reveal" href={c.href} aria-label={c.aria}>
            <div class="ux-frame">
              <div class="ux-bar">
                <span class="ux-dot"></span><span class="ux-dot"></span><span class="ux-dot"></span>
                <span class="ux-url mono">{c.url}</span>
              </div>
              {c.img ? (
                <div class="ux-prev ux-prev--photo">
                  <Image class="ux-shot" src={c.img} alt={c.imgAlt} width={700} format="webp" quality={75} loading="lazy" decoding="async" />
                  <span class="ux-badge mono">DEMO</span>
                </div>
              ) : (
                <div class={`ux-prev ux-prev--${c.prev} ux-prev--pages`}>
                  <span class="ux-pages" aria-hidden="true"><i></i><i></i><i></i></span>
                  <span class="ux-badge mono">DEMO</span>
                </div>
              )}
            </div>
            <div class="ux-meta">
              <span class="kicker mono ux-tag" data-i18n={c.tag}>{c.tagFallback}</span>
              <h4 class="ux-name" data-i18n={c.h}>{c.hFallback}</h4>
              <p data-i18n={c.p}>{c.pFallback}</p>
              <span class="ux-go"><span data-i18n="demos.live">Prohlédnout ukázku</span><span class="ux-arrow" aria-hidden="true">→</span></span>
            </div>
          </a>
        ) : (
          <div class="ux-card ux-card--soon reveal" aria-label="Připravovaná vícestránková ukázka">
            <div class="ux-frame">
              <div class="ux-bar">
                <span class="ux-dot"></span><span class="ux-dot"></span><span class="ux-dot"></span>
                <span class="ux-url mono">{c.url}</span>
              </div>
              <div class={`ux-prev ux-prev--${c.prev} ux-prev--pages`}>
                <span class="ux-pages" aria-hidden="true"><i></i><i></i><i></i></span>
                <span class="ux-badge ux-badge--soon mono" data-i18n="demos.soon">Připravujeme</span>
              </div>
            </div>
            <div class="ux-meta">
              <span class="kicker mono ux-tag" data-i18n={c.tag}>{c.tagFallback}</span>
              <h4 class="ux-name" data-i18n={c.h}>{c.hFallback}</h4>
              <p data-i18n={c.p}>{c.pFallback}</p>
              <span class="ux-go ux-go--muted"><span data-i18n="demos.soon2">Brzy k dispozici</span></span>
            </div>
          </div>
        )
      ))}
    </div>

    <p class="ux-note mono reveal" data-i18n="demos.note">Ukázkové weby, ne reální klienti. Slouží jako důkaz, co pro váš obor dokážu připravit.</p>
  </div>
</section>

<style>
  .showcase { position: relative; }

  .ux-cat { display: flex; align-items: baseline; gap: 16px; margin: 8px 0 18px; }
  .ux-cat--mt { margin-top: 48px; }
  .ux-cat__num { color: var(--accent); font-size: .8rem; font-weight: 600; }
  .ux-cat__h { font-size: 1.5rem; margin: 0; }
  .ux-cat__s { color: var(--ink-soft); margin: 4px 0 0; font-size: .95rem; max-width: 46ch; }

  .ux-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .ux-grid--2 { grid-template-columns: repeat(2, 1fr); max-width: 760px; }

  .ux-card {
    display: flex; flex-direction: column;
    background: var(--panel); border: 1px solid var(--line);
    border-radius: var(--r); overflow: hidden; color: inherit;
    box-shadow: var(--shadow);
    transition: transform .28s var(--ease), border-color .28s var(--ease), box-shadow .28s var(--ease);
  }
  .ux-card--live { cursor: pointer; }
  .ux-card--live:hover { transform: translateY(-5px); border-color: color-mix(in srgb, var(--accent) 55%, var(--line)); }
  .ux-card--live:focus-visible { outline: 2.5px solid var(--accent); outline-offset: 3px; }
  .ux-card--soon { opacity: .9; }

  .ux-frame { border-bottom: 1px solid var(--line-soft); }
  .ux-bar { display: flex; align-items: center; gap: 6px; padding: 9px 12px; background: var(--panel-2); border-bottom: 1px solid var(--line-soft); }
  .ux-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--line); }
  .ux-card--live .ux-dot:first-child { background: var(--accent); }
  .ux-url { margin-left: 8px; font-size: .58rem !important; letter-spacing: .04em !important; text-transform: none !important; color: var(--ink-faint); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .ux-prev { position: relative; aspect-ratio: 22 / 13; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .ux-art { width: 86%; height: 86%; }

  /* live multi-page card with a real screenshot/photo */
  .ux-prev--photo { background: var(--panel-2); }
  .ux-shot { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .4s var(--ease); }
  .ux-card--live:hover .ux-shot { transform: scale(1.04); }
  .ux-ln { fill: none; stroke: var(--ink-soft); stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .ux-ln--ink { stroke: var(--ink); }
  .ux-ln--accent { stroke: var(--accent); }
  .ux-fill { fill: var(--accent); }

  .ux-prev--wood { background: repeating-linear-gradient(96deg, color-mix(in srgb, var(--copper) 8%, transparent) 0 2px, transparent 2px 9px), linear-gradient(160deg, color-mix(in srgb, var(--copper) 16%, var(--panel-2)), var(--panel-2)); }
  .ux-prev--cafe { background: radial-gradient(120% 100% at 20% 10%, color-mix(in srgb, var(--copper) 18%, transparent), transparent 60%), linear-gradient(160deg, color-mix(in srgb, var(--copper) 10%, var(--panel-2)), var(--panel-2)); }
  .ux-prev--fit { background: radial-gradient(120% 120% at 80% 0%, color-mix(in srgb, var(--accent-2) 22%, transparent), transparent 60%), linear-gradient(160deg, color-mix(in srgb, var(--accent-2) 10%, var(--panel-2)), var(--panel-2)); }
  .ux-prev--salon { background: radial-gradient(120% 100% at 20% 10%, color-mix(in srgb, var(--accent-2) 16%, transparent), transparent 60%), linear-gradient(160deg, color-mix(in srgb, var(--accent-2) 10%, var(--panel-2)), var(--panel-2)); }
  .ux-prev--ink { background: radial-gradient(120% 120% at 80% 0%, color-mix(in srgb, var(--accent) 14%, transparent), transparent 62%), linear-gradient(160deg, color-mix(in srgb, var(--ink) 10%, var(--panel-2)), var(--panel-2)); }

  /* multi-page preview: stacked sheets */
  .ux-prev--pages .ux-pages { position: relative; width: 54px; height: 64px; }
  .ux-pages i { position: absolute; inset: 0; border: 1.5px solid var(--line); border-radius: 4px; background: var(--panel); }
  .ux-pages i:nth-child(1) { transform: translate(-10px, -6px) rotate(-6deg); }
  .ux-pages i:nth-child(2) { transform: translate(0, 0) rotate(2deg); }
  .ux-pages i:nth-child(3) { transform: translate(10px, 6px) rotate(8deg); border-color: color-mix(in srgb, var(--accent) 45%, var(--line)); }

  .ux-badge { position: absolute; top: 10px; right: 10px; font-size: .56rem !important; background: var(--ink); color: var(--bg); padding: 3px 8px; border-radius: 4px; letter-spacing: .16em !important; }
  .ux-badge--soon { background: transparent; color: var(--ink-soft); border: 1px solid var(--line); }

  .ux-meta { padding: 18px 20px 20px; display: flex; flex-direction: column; gap: 4px; flex: 1; }
  .ux-tag { color: var(--accent); margin-bottom: 2px; }
  .ux-name { font-size: 1.22rem; margin: 0; }
  .ux-meta p { color: var(--ink-soft); font-size: .95rem; margin-top: 2px; }
  .ux-go { margin-top: auto; padding-top: 12px; display: inline-flex; align-items: center; gap: .5em; font-family: var(--ff-mono); font-size: .72rem; letter-spacing: .1em; text-transform: uppercase; color: var(--accent); font-weight: 500; }
  .ux-go--muted { color: var(--ink-faint); }
  .ux-arrow { transition: transform .22s var(--ease); }
  .ux-card--live:hover .ux-arrow { transform: translateX(4px); }

  .ux-note { text-align: center; margin-top: 30px; color: var(--ink-faint); font-size: .66rem !important; letter-spacing: .1em !important; }

  @media (max-width: 900px) {
    .ux-grid, .ux-grid--2 { grid-template-columns: 1fr; max-width: 460px; margin-inline: auto; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ux-card, .ux-arrow { transition: none; }
    .ux-card--live:hover { transform: none; }
  }
</style>
